{%- liquid
  assign hero_heading = section.settings.hero_heading
  if hero_heading == blank
    assign hero_heading = collection.title
  endif
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign active_count = 0
  for filter in collection.filters
    assign active_count = active_count | plus: filter.active_values.size
  endfor
-%}

<section class="section--tight mc" data-section-id="{{ section.id }}">
  <div class="container">

    {%- comment -%} Breadcrumb {%- endcomment -%}
    <p class="mc-crumb">{{ section.settings.breadcrumb_root }} <span>/</span> {{ collection.title }}</p>

    {%- comment -%} Filter + sort bar {%- endcomment -%}
    <form method="get" class="mc-bar" data-facet-form>
      <div class="mc-bar__filters">
        <span class="mc-bar__label">Filter by</span>
        {%- if collection.filters.size > 0 -%}
          {%- for filter in collection.filters -%}
            {%- if filter.type == 'list' or filter.type == 'boolean' -%}
              <span class="mc-select">
                <select name="{{ filter.param_name }}" aria-label="{{ filter.label | escape }}" onchange="this.form.submit()">
                  <option value="">{{ filter.label }}</option>
                  {%- for value in filter.values -%}
                    <option value="{{ value.value }}" {% if value.active %}selected{% endif %}>{{ value.label }} ({{ value.count }})</option>
                  {%- endfor -%}
                </select>
              </span>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Placeholder dropdowns until storefront filters are configured {%- endcomment -%}
          {%- assign placeholders = 'Category,Collections,Size,Color' | split: ',' -%}
          {%- for ph in placeholders -%}
            <span class="mc-select">
              <select aria-label="{{ ph }}" disabled>
                <option>{{ ph }}</option>
              </select>
            </span>
          {%- endfor -%}
        {%- endif -%}
        <span class="mc-bar__count">{{ collection.products_count }} results</span>
      </div>

      <div class="mc-bar__sort">
        <span class="mc-bar__label">Sort by</span>
        <span class="mc-select mc-select--plain">
          <select name="sort_by" aria-label="Sort by" onchange="this.form.submit()">
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>
            {%- endfor -%}
          </select>
        </span>
      </div>
    </form>

    {%- comment -%} Applied filters {%- endcomment -%}
    {%- if active_count > 0 -%}
      <div class="mc-applied">
        <span class="mc-applied__label">Applied</span>
        {%- for filter in collection.filters -%}
          {%- for value in filter.active_values -%}
            <a class="mc-chip" href="{{ value.remove_url }}">{{ value.label }} <span aria-hidden="true">&times;</span></a>
          {%- endfor -%}
        {%- endfor -%}
        <a class="mc-applied__clear" href="{{ collection.url }}">Clear all</a>
      </div>
    {%- endif -%}

    {%- comment -%} Hero / promo band {%- endcomment -%}
    {%- if section.settings.show_hero -%}
      <div class="mc-hero">
        <div class="mc-hero__text">
          <h1 class="mc-hero__title">{{ hero_heading }}</h1>
          {%- if section.settings.hero_text != blank -%}
            <p class="mc-hero__sub">{{ section.settings.hero_text }}</p>
          {%- endif -%}
          {%- if section.blocks.size > 0 -%}
            <div class="mc-hero__cats">
              {%- for block in section.blocks -%}
                <a href="{{ block.settings.link }}" class="mc-cat" {{ block.shopify_attributes }}>
                  <span class="mc-cat__img">
                    {%- if block.settings.image != blank -%}
                      <img src="{{ block.settings.image | image_url: width: 320 }}" alt="{{ block.settings.title | escape }}" width="160" height="160" loading="lazy">
                    {%- else -%}
                      {{ 'collection-1' | placeholder_svg_tag }}
                    {%- endif -%}
                  </span>
                  <span class="mc-cat__label">{{ block.settings.title }}</span>
                </a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
        <div class="mc-hero__media">
          {%- if section.settings.hero_image != blank -%}
            <img src="{{ section.settings.hero_image | image_url: width: 1200 }}" alt="{{ hero_heading | escape }}" width="1200" height="900" loading="lazy">
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Product grid {%- endcomment -%}
    {%- paginate collection.products by section.settings.per_page -%}
      {%- if collection.products.size > 0 -%}
        <div class="grid grid--4 mc-grid">
          {%- for product in collection.products -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        </div>

        {%- comment -%} Pagination {%- endcomment -%}
        {%- if paginate.pages > 1 -%}
          <nav class="mc-pager" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a class="mc-pager__arrow" href="{{ paginate.previous.url }}" aria-label="Previous">{% render 'icon', icon: 'arrow-left' %}</a>
            {%- else -%}
              <span class="mc-pager__arrow is-disabled">{% render 'icon', icon: 'arrow-left' %}</span>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a class="mc-pager__num" href="{{ part.url }}">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}
                <span class="mc-pager__num is-current" aria-current="page">{{ part.title }}</span>
              {%- else -%}
                <span class="mc-pager__num mc-pager__gap">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a class="mc-pager__arrow" href="{{ paginate.next.url }}" aria-label="Next">{% render 'icon', icon: 'arrow-right' %}</a>
            {%- else -%}
              <span class="mc-pager__arrow is-disabled">{% render 'icon', icon: 'arrow-right' %}</span>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="mc-empty">
          <p class="eyebrow">Nothing here yet</p>
          <h2 class="section-heading">No products <em>found</em></h2>
          <p class="section-sub">Try clearing your filters or explore the full collection.</p>
          <a class="btn" href="{{ routes.all_products_collection_url }}">Shop all</a>
        </div>
      {%- endif -%}
    {%- endpaginate -%}

  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .mc-crumb { font-size: 12px; letter-spacing: .2em; text-transform: uppercase; color: var(--brown); margin: 0 0 34px; }
  #shopify-section-{{ section.id }} .mc-crumb span { color: var(--taupe); margin: 0 6px; }

  #shopify-section-{{ section.id }} .mc-bar { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; padding-bottom: 26px; border-bottom: 1px solid var(--line); }
  #shopify-section-{{ section.id }} .mc-bar__filters { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  #shopify-section-{{ section.id }} .mc-bar__sort { display: flex; align-items: center; gap: 16px; }
  #shopify-section-{{ section.id }} .mc-bar__label { font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--muted); }
  #shopify-section-{{ section.id }} .mc-bar__count { font-size: 13px; letter-spacing: .1em; color: var(--brown); font-weight: 400; }

  #shopify-section-{{ section.id }} .mc-select { position: relative; display: inline-flex; }
  #shopify-section-{{ section.id }} .mc-select::after { content: ''; position: absolute; right: 4px; top: 50%; width: 7px; height: 7px; border-right: 1.4px solid var(--brown); border-bottom: 1.4px solid var(--brown); transform: translateY(-70%) rotate(45deg); pointer-events: none; }
  #shopify-section-{{ section.id }} .mc-select select { appearance: none; -webkit-appearance: none; background: transparent; border: none; border-bottom: 1px solid var(--line); border-radius: 0; padding: 6px 24px 6px 0; font-size: 14px; color: var(--brown); letter-spacing: .04em; min-width: 118px; cursor: pointer; }
  #shopify-section-{{ section.id }} .mc-select select:focus { border-color: var(--taupe); }
  #shopify-section-{{ section.id }} .mc-select select:disabled { color: var(--brown); opacity: 1; cursor: default; }
  #shopify-section-{{ section.id }} .mc-select--plain select { min-width: 150px; }

  #shopify-section-{{ section.id }} .mc-applied { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin: 24px 0 0; }
  #shopify-section-{{ section.id }} .mc-applied__label { font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--muted); }
  #shopify-section-{{ section.id }} .mc-chip { display: inline-flex; align-items: center; gap: 10px; background: var(--brown); color: #fff; font-size: 12px; letter-spacing: .1em; padding: 8px 16px; border-radius: 999px; }
  #shopify-section-{{ section.id }} .mc-chip span { font-size: 14px; line-height: 1; }
  #shopify-section-{{ section.id }} .mc-chip:hover { background: var(--brown-2); }
  #shopify-section-{{ section.id }} .mc-applied__clear { font-family: var(--font-serif); font-style: italic; color: var(--brown); font-size: 15px; }
  #shopify-section-{{ section.id }} .mc-applied__clear:hover { color: var(--taupe); }

  #shopify-section-{{ section.id }} .mc-hero { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: stretch; background: var(--cream-2); border-radius: var(--radius-lg); padding: 60px; margin: 40px 0 60px; }
  #shopify-section-{{ section.id }} .mc-hero__title { font-family: var(--font-serif); font-size: clamp(34px, 4vw, 48px); color: var(--brown); }
  #shopify-section-{{ section.id }} .mc-hero__sub { color: var(--muted); max-width: 420px; margin: 18px 0 0; }
  #shopify-section-{{ section.id }} .mc-hero__cats { display: flex; flex-wrap: wrap; gap: 34px; margin-top: 40px; }
  #shopify-section-{{ section.id }} .mc-cat { display: flex; flex-direction: column; align-items: center; gap: 16px; width: 96px; text-align: center; }
  #shopify-section-{{ section.id }} .mc-cat__img { width: 96px; height: 96px; border-radius: 50%; overflow: hidden; background: var(--sand); display: block; }
  #shopify-section-{{ section.id }} .mc-cat__img img, #shopify-section-{{ section.id }} .mc-cat__img svg { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; }
  #shopify-section-{{ section.id }} .mc-cat:hover .mc-cat__img img { transform: scale(1.06); }
  #shopify-section-{{ section.id }} .mc-cat__label { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--brown); }
  #shopify-section-{{ section.id }} .mc-hero__media { border-radius: var(--radius); overflow: hidden; min-height: 320px; }
  #shopify-section-{{ section.id }} .mc-hero__media img, #shopify-section-{{ section.id }} .mc-hero__media svg { width: 100%; height: 100%; object-fit: cover; }

  #shopify-section-{{ section.id }} .mc-grid { margin-top: 10px; }

  #shopify-section-{{ section.id }} .mc-pager { display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 60px; }
  #shopify-section-{{ section.id }} .mc-pager__num { display: inline-flex; align-items: center; justify-content: center; min-width: 34px; height: 34px; font-size: 14px; letter-spacing: .06em; color: var(--muted); }
  #shopify-section-{{ section.id }} .mc-pager__num:hover { color: var(--brown); }
  #shopify-section-{{ section.id }} .mc-pager__num.is-current { color: var(--brown); font-weight: 500; border-bottom: 1.5px solid var(--brown); }
  #shopify-section-{{ section.id }} .mc-pager__gap { color: var(--muted); }
  #shopify-section-{{ section.id }} .mc-pager__arrow { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; color: var(--brown); }
  #shopify-section-{{ section.id }} .mc-pager__arrow.is-disabled { color: var(--line); pointer-events: none; }

  #shopify-section-{{ section.id }} .mc-empty { text-align: center; padding: 70px 0; }
  #shopify-section-{{ section.id }} .mc-empty .btn { margin-top: 26px; }

  @media (max-width: 990px) {
    #shopify-section-{{ section.id }} .mc-hero { grid-template-columns: 1fr; padding: 36px; gap: 34px; }
    #shopify-section-{{ section.id }} .mc-hero__media { min-height: 260px; }
  }
  @media (max-width: 700px) {
    #shopify-section-{{ section.id }} .mc-bar { flex-direction: column; align-items: flex-start; gap: 18px; }
    #shopify-section-{{ section.id }} .mc-hero__cats { gap: 22px; }
    #shopify-section-{{ section.id }} .mc-cat, #shopify-section-{{ section.id }} .mc-cat__img { width: 78px; }
    #shopify-section-{{ section.id }} .mc-cat__img { height: 78px; }
  }
</style>

{% schema %}
{
  "name": "Main collection",
  "settings": [
    { "type": "text", "id": "breadcrumb_root", "label": "Breadcrumb root", "default": "Shop" },
    { "type": "range", "id": "per_page", "label": "Products per page", "min": 8, "max": 24, "step": 4, "default": 12 },
    { "type": "header", "content": "Hero band" },
    { "type": "checkbox", "id": "show_hero", "label": "Show hero band", "default": true },
    { "type": "text", "id": "hero_heading", "label": "Hero heading", "info": "Leave blank to use the collection title", "default": "Bedding" },
    { "type": "textarea", "id": "hero_text", "label": "Hero text", "default": "Join the Beds & More community for styling notes, new shades and a welcome treat on your first order." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category circle",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Bedsheets" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Main collection",
      "blocks": [
        { "type": "category", "settings": { "title": "Bedsheets" } },
        { "type": "category", "settings": { "title": "Bed Covers" } },
        { "type": "category", "settings": { "title": "Pillows" } },
        { "type": "category", "settings": { "title": "Comforters" } }
      ]
    }
  ]
}
{% endschema %}
