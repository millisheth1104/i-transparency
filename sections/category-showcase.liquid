<section class="section category-showcase">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subtext != blank -%}<p class="section-sub">{{ section.settings.subtext }}</p>{%- endif -%}

    <div class="cat-row" data-scroll>
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="cat-card" {{ block.shopify_attributes }}>
          <div class="cat-card__media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.title | escape }}" width="900" height="1100" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <span class="cat-card__num">/{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <span class="cat-card__title">{{ block.settings.title }}</span>
        </a>
      {%- endfor -%}
    </div>

    <div class="cat-foot">
      <a class="btn" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
      <div class="cat-nav">
        <button class="round-btn" data-scroll-prev aria-label="Previous">{% render 'icon', icon: 'arrow-left' %}</button>
        <button class="round-btn" data-scroll-next aria-label="Next">{% render 'icon', icon: 'arrow-right' %}</button>
      </div>
    </div>
  </div>
</section>

<style>
  .cat-row { display: flex; gap: 22px; overflow-x: auto; scroll-behavior: smooth; padding: 40px 0 10px; scrollbar-width: none; }
  .cat-row::-webkit-scrollbar { display: none; }
  .cat-card { position: relative; flex: 0 0 clamp(280px, 42vw, 620px); border-radius: var(--radius); overflow: hidden; }
  .cat-card:first-child { flex-basis: clamp(320px, 55vw, 760px); }
  .cat-card__media { aspect-ratio: 4/3; }
  .cat-card__media img, .cat-card__media svg { width: 100%; height: 100%; object-fit: cover; transition: transform .6s; }
  .cat-card:hover .cat-card__media img { transform: scale(1.04); }
  .cat-card__num { position: absolute; top: 26px; left: 30px; color: rgba(255,255,255,.85); font-size: 13px; letter-spacing: .08em; }
  .cat-card__title { position: absolute; top: 44px; left: 30px; color: #fff; font-family: var(--font-serif); font-size: 34px; }
  .cat-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 20px; }
  .cat-nav { display: flex; gap: 12px; }
</style>

<script>
  document.querySelectorAll('.category-showcase').forEach(function(sec){
    var row = sec.querySelector('[data-scroll]');
    var amt = function(){ return Math.min(row.clientWidth * 0.7, 640); };
    sec.querySelector('[data-scroll-next]')?.addEventListener('click', function(){ row.scrollBy({left: amt(), behavior:'smooth'}); });
    sec.querySelector('[data-scroll-prev]')?.addEventListener('click', function(){ row.scrollBy({left: -amt(), behavior:'smooth'}); });
  });
</script>

{% schema %}
{
  "name": "Category showcase",
  "settings": [
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Shop by <em>category</em>" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "One knitted-cotton family, three ways to layer your bed — across nine shades drawn from the earth." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "View all" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category showcase",
      "blocks": [
        { "type": "category", "settings": { "title": "Bed covers" } },
        { "type": "category", "settings": { "title": "Comforters" } },
        { "type": "category", "settings": { "title": "Throws" } },
        { "type": "category", "settings": { "title": "Pillow covers" } },
        { "type": "category", "settings": { "title": "Cushions" } }
      ]
    }
  ]
}
{% endschema %}
