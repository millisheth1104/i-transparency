<section class="section category-showcase">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subtext != blank -%}<p class="section-sub">{{ section.settings.subtext }}</p>{%- endif -%}

    <div class="cat-fan">
      {%- for block in section.blocks -%}
        {%- if forloop.first -%}
          <div class="cat-card cat-card--main" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="cat-card__media">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.title | escape }}" width="1200" height="900" loading="lazy">
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag }}
              {%- endif -%}
            </a>
            <span class="cat-card__num">/{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <a href="{{ block.settings.link }}" class="cat-card__title">{{ block.settings.title }}</a>
            <a class="btn cat-card__view" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
            <a class="round-btn cat-card__next" href="{{ section.settings.button_link }}" aria-label="{{ section.settings.button_label }}">{% render 'icon', icon: 'arrow-right' %}</a>
          </div>
        {%- else -%}
          <a href="{{ block.settings.link }}" class="cat-card cat-card--side" {{ block.shopify_attributes }}>
            <div class="cat-card__media">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.title | escape }}" width="500" height="700" loading="lazy">
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag }}
              {%- endif -%}
            </div>
            <span class="cat-card__num cat-card__num--side">/{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .cat-fan { position: relative; height: 460px; margin-top: 40px; overflow: hidden; }
  .cat-card--main { position: absolute; left: 0; top: 0; width: 58%; height: 100%; border-radius: var(--radius); overflow: hidden; z-index: 5; background: var(--cream-2); }
  .cat-card--main::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(20,16,12,0) 45%, rgba(20,16,12,.4) 100%); pointer-events: none; }
  .cat-card__media { position: absolute; inset: 0; display: block; }
  .cat-card__media img, .cat-card__media svg { width: 100%; height: 100%; object-fit: cover; }
  .cat-card__num { position: absolute; top: 26px; left: 30px; color: rgba(255,255,255,.85); font-size: 13px; letter-spacing: .08em; z-index: 2; }
  .cat-card__title { position: absolute; top: 44px; left: 30px; color: #fff; font-family: var(--font-serif); font-size: 34px; z-index: 2; }
  .cat-card__view { position: absolute; left: 30px; bottom: 30px; z-index: 2; }
  .cat-card__next { position: absolute; right: 30px; bottom: 30px; z-index: 2; background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.6); color: #fff; }
  .cat-card__next:hover { background: #fff; color: var(--brown); }

  .cat-card--side { position: absolute; width: 190px; border-radius: var(--radius); overflow: hidden; box-shadow: -10px 0 24px rgba(40,32,24,.15); transition: transform .3s; }
  .cat-card--side:nth-child(2) { left: calc(58% - 60px); top: 12px; height: 400px; z-index: 4; }
  .cat-card--side:nth-child(3) { left: calc(58% + 70px); top: 28px; height: 360px; z-index: 3; }
  .cat-card--side:nth-child(4) { left: calc(58% + 190px); top: 46px; height: 320px; z-index: 2; }
  .cat-card--side:nth-child(5) { left: calc(58% + 300px); top: 64px; height: 280px; z-index: 1; }
  .cat-card--side:hover { transform: translateY(-8px); }
  .cat-card--side .cat-card__media { position: static; width: 100%; height: 100%; }
  .cat-card__num--side { position: absolute; top: 16px; left: 16px; color: rgba(255,255,255,.9); font-size: 11px; letter-spacing: .08em; z-index: 2; }

  @media (max-width: 860px) {
    .cat-fan { height: 340px; }
    .cat-card--main { width: 78%; }
    .cat-card--side { width: 110px; }
    .cat-card--side:nth-child(2) { left: calc(78% - 40px); height: 290px; }
    .cat-card--side:nth-child(3) { left: calc(78% + 40px); height: 260px; }
    .cat-card--side:nth-child(4) { left: calc(78% + 120px); height: 230px; }
    .cat-card--side:nth-child(5) { left: calc(78% + 200px); height: 200px; }
    .cat-card__title { font-size: 24px; }
  }
</style>

{% schema %}
{
  "name": "Category showcase",
  "settings": [
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Shop by <em>category</em>" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "One knitted-cotton family, three ways to layer your bed — across nine shades drawn from the earth." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "View all" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category showcase",
      "blocks": [
        { "type": "category", "settings": { "title": "Bed covers" } },
        { "type": "category", "settings": { "title": "Comforters" } },
        { "type": "category", "settings": { "title": "Throws" } },
        { "type": "category", "settings": { "title": "Pillow covers" } },
        { "type": "category", "settings": { "title": "Cushions" } }
      ]
    }
  ]
}
{% endschema %}
