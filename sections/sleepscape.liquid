<section class="section sleepscape">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subtext != blank -%}<p class="section-sub">{{ section.settings.subtext }}</p>{%- endif -%}

    <div class="sleepscape__stage">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}" width="2000" height="1200" loading="lazy">
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- assign prod = all_products[block.settings.product] -%}
        <div class="hotspot" data-hotspot style="left: {{ block.settings.x }}%; top: {{ block.settings.y }}%;" {{ block.shopify_attributes }}>
          <button class="hotspot__dot" aria-label="View product" data-hotspot-toggle>+</button>
          {%- if prod != empty -%}
            <div class="hotspot__card">
              <div class="hotspot__card-media">
                {%- if prod.featured_image -%}<img src="{{ prod.featured_image | image_url: width: 300 }}" alt="{{ prod.title | escape }}" width="300" height="300">{%- endif -%}
                <button class="product-card__wish" aria-label="Wishlist">{% render 'icon', icon: 'heart' %}</button>
              </div>
              <div class="hotspot__card-body">
                <p class="hotspot__card-title">{{ prod.title }}</p>
                {%- if block.settings.subtitle != blank -%}<p class="product-card__meta">{{ block.settings.subtitle }}</p>{%- endif -%}
                <span class="product-card__price">{{ prod.price | money_without_trailing_zeros }}</span>
                <a class="product-card__add" href="{{ prod.url }}">Add to cart</a>
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .sleepscape__stage { position: relative; margin-top: 40px; border-radius: var(--radius); overflow: hidden; aspect-ratio: 16/9; }
  .sleepscape__stage > img, .sleepscape__stage > svg { width: 100%; height: 100%; object-fit: cover; }
  .hotspot { position: absolute; transform: translate(-50%, -50%); }
  .hotspot__dot { width: 34px; height: 34px; border-radius: 50%; background: rgba(255,255,255,.9); border: none; color: var(--brown); font-size: 20px; line-height: 1; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 14px rgba(0,0,0,.15); }
  .hotspot__card { position: absolute; top: 44px; left: 50%; transform: translateX(-50%) translateY(8px); width: 169.07px; background: var(--white); border: 1px solid var(--taupe-dark); border-radius: 0; opacity: 0; pointer-events: none; transition: opacity .25s, transform .25s; box-shadow: 0 20px 45px rgba(45,38,32,.18); z-index: 3; }
  .hotspot:hover .hotspot__card, .hotspot:focus-within .hotspot__card, .hotspot.is-open .hotspot__card { opacity: 1; pointer-events: auto; transform: translateX(-50%) translateY(0); }
  .hotspot__dot { position: relative; z-index: 2; transition: background .2s, color .2s; }
  .hotspot.is-open .hotspot__dot { background: var(--brown); color: #fff; }
  .hotspot__card-media { position: relative; width: 153.07px; height: 108px; margin: 8px auto 0; background: var(--white); display: flex; align-items: center; justify-content: center; }
  .hotspot__card-media img { width: 100%; height: 100%; object-fit: contain; }
  .hotspot__card-body { padding: 8px 10px 10px; }
  .hotspot__card-title { font-family: var(--font-ui); font-size: 13px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--brown); margin: 0 0 6px; }
  .hotspot__card .product-card__meta { margin: 0 0 4px; font-size: 11px; }
  .hotspot__card .product-card__price { display: block; margin: 4px 0 10px; font-size: 15px; }
  .hotspot__card .product-card__add { height: 38px; font-size: 9px; letter-spacing: .12em; }
  .hotspot__card .product-card__wish { top: 8px; right: 8px; z-index: 4; }
</style>

<script>
  document.querySelectorAll('.sleepscape [data-hotspot]').forEach(function (hotspot) {
    var toggle = hotspot.querySelector('[data-hotspot-toggle]');
    if (!toggle) return;
    toggle.addEventListener('click', function (e) {
      e.stopPropagation();
      var wasOpen = hotspot.classList.contains('is-open');
      document.querySelectorAll('.sleepscape .hotspot.is-open').forEach(function (h) { h.classList.remove('is-open'); });
      if (!wasOpen) hotspot.classList.add('is-open');
    });
  });
  document.addEventListener('click', function () {
    document.querySelectorAll('.sleepscape .hotspot.is-open').forEach(function (h) { h.classList.remove('is-open'); });
  });
</script>

{% schema %}
{
  "name": "Sleepscape",
  "settings": [
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Build your <em>sleepscape</em>" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Tap a piece to add it — build the layered look in one go." },
    { "type": "image_picker", "id": "image", "label": "Room image" }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Ivory · 2N Pillow Covers" },
        { "type": "range", "id": "x", "label": "Horizontal %", "min": 0, "max": 100, "step": 1, "default": 40 },
        { "type": "range", "id": "y", "label": "Vertical %", "min": 0, "max": 100, "step": 1, "default": 50 }
      ]
    }
  ],
  "presets": [
    { "name": "Sleepscape", "blocks": [ { "type": "hotspot", "settings": { "x": 35, "y": 55 } }, { "type": "hotspot", "settings": { "x": 62, "y": 40 } } ] }
  ]
}
{% endschema %}
