<section class="section category-showcase">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subtext != blank -%}<p class="section-sub">{{ section.settings.subtext }}</p>{%- endif -%}

    <div class="cat-fan" data-cat-fan>
      <div class="cat-card cat-card--main" data-cat-slot="0">
        <a href="#" class="cat-card__media" data-cat-link>
          <img data-cat-img src="" alt="" width="1200" height="900" loading="lazy">
        </a>
        <span class="cat-card__num" data-cat-num></span>
        <a href="#" class="cat-card__title" data-cat-title data-cat-link></a>
        <a class="btn cat-card__view" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
        <button class="round-btn cat-card__next" data-cat-next aria-label="Next category">{% render 'icon', icon: 'arrow-right' %}</button>
      </div>
      {%- for i in (1..4) -%}
        <a href="#" class="cat-card cat-card--side" data-cat-slot="{{ i }}" data-cat-link>
          <div class="cat-card__media">
            <img data-cat-img src="" alt="" width="500" height="700" loading="lazy">
          </div>
          <span class="cat-card__num cat-card__num--side" data-cat-num></span>
        </a>
      {%- endfor -%}
    </div>

    <script type="application/json" data-cat-data>
      [
        {%- for block in section.blocks -%}
          {
            "title": {{ block.settings.title | json }},
            "link": {{ block.settings.link | json }},
            "image": {{ block.settings.image | image_url: width: 1200 | json }},
            "num": "/{{ forloop.index | prepend: '0' | slice: -2, 2 }}"
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    </script>
  </div>
</section>

<style>
  .cat-fan { position: relative; height: 460px; margin-top: 40px; overflow: hidden; }
  .cat-card--main { position: absolute; left: 0; top: 0; width: 58%; height: 100%; border-radius: var(--radius); overflow: hidden; z-index: 5; background: var(--cream-2); }
  .cat-card--main::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(20,16,12,0) 45%, rgba(20,16,12,.4) 100%); pointer-events: none; }
  .cat-card__media { position: absolute; inset: 0; display: block; background: var(--cream-2); }
  .cat-card__media img { width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity .35s ease; }
  .cat-card__media img[src]:not([src=""]) { opacity: 1; }
  .cat-card__num { position: absolute; top: 26px; left: 30px; color: var(--brown-2); font-size: 13px; letter-spacing: .08em; z-index: 2; }
  .cat-card__title { position: absolute; top: 44px; left: 30px; color: var(--brown); font-family: var(--font-serif); font-size: 34px; z-index: 2; }
  .cat-card__view { position: absolute; left: 30px; bottom: 30px; z-index: 2; }
  .cat-card__next { position: absolute; right: 30px; bottom: 30px; z-index: 2; background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.6); color: #fff; }
  .cat-card__next:hover { background: #fff; color: var(--brown); }

  .cat-card--side { position: absolute; width: 190px; border-radius: var(--radius); overflow: hidden; box-shadow: -10px 0 24px rgba(40,32,24,.15); transition: transform .3s; }
  .cat-card--side[data-cat-slot="1"] { left: calc(58% - 60px); top: 12px; height: 400px; z-index: 4; }
  .cat-card--side[data-cat-slot="2"] { left: calc(58% + 70px); top: 28px; height: 360px; z-index: 3; }
  .cat-card--side[data-cat-slot="3"] { left: calc(58% + 190px); top: 46px; height: 320px; z-index: 2; }
  .cat-card--side[data-cat-slot="4"] { left: calc(58% + 300px); top: 64px; height: 280px; z-index: 1; }
  .cat-card--side:hover { transform: translateY(-8px); }
  .cat-card--side .cat-card__media { position: static; width: 100%; height: 100%; }
  .cat-card__num--side { position: absolute; top: 16px; left: 16px; color: rgba(255,255,255,.9); font-size: 11px; letter-spacing: .08em; z-index: 2; }

  .cat-fan.is-fading .cat-card__media img { opacity: 0 !important; }

  @media (max-width: 860px) {
    .cat-fan { height: 340px; }
    .cat-card--main { width: 78%; }
    .cat-card--side { width: 110px; }
    .cat-card--side[data-cat-slot="1"] { left: calc(78% - 40px); height: 290px; }
    .cat-card--side[data-cat-slot="2"] { left: calc(78% + 40px); height: 260px; }
    .cat-card--side[data-cat-slot="3"] { left: calc(78% + 120px); height: 230px; }
    .cat-card--side[data-cat-slot="4"] { left: calc(78% + 200px); height: 200px; }
    .cat-card__title { font-size: 24px; }
  }
</style>

<script>
  document.querySelectorAll('[data-cat-fan]').forEach(function (fan) {
    if (fan.dataset.catInit) return;
    fan.dataset.catInit = '1';

    var dataEl = fan.parentElement.querySelector('[data-cat-data]');
    var slides = [];
    try { slides = JSON.parse(dataEl.textContent); } catch (e) { slides = []; }
    if (!slides.length) return;

    var slots = Array.prototype.slice.call(fan.querySelectorAll('[data-cat-slot]'));
    var start = 0;

    function paint() {
      slots.forEach(function (slot, i) {
        var data = slides[(start + i) % slides.length];
        var img = slot.querySelector('[data-cat-img]');
        var num = slot.querySelector('[data-cat-num]');
        var title = slot.querySelector('[data-cat-title]');
        if (img) img.src = data.image || '';
        if (img) img.alt = data.title || '';
        if (num) num.textContent = data.num || '';
        if (title) title.textContent = data.title || '';
        slot.querySelectorAll('[data-cat-link]').forEach(function (a) { a.href = data.link || '#'; });
      });
    }

    paint();

    var next = fan.querySelector('[data-cat-next]');
    if (next) {
      next.addEventListener('click', function (e) {
        e.preventDefault();
        if (fan.classList.contains('is-fading')) return;
        fan.classList.add('is-fading');
        setTimeout(function () {
          start = (start + 1) % slides.length;
          paint();
          fan.classList.remove('is-fading');
        }, 220);
      });
    }
  });
</script>

{% schema %}
{
  "name": "Category showcase",
  "settings": [
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Shop by <em>category</em>" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "One knitted-cotton family, three ways to layer your bed — across nine shades drawn from the earth." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "View all" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category showcase",
      "blocks": [
        { "type": "category", "settings": { "title": "Bed covers" } },
        { "type": "category", "settings": { "title": "Comforters" } },
        { "type": "category", "settings": { "title": "Throws" } },
        { "type": "category", "settings": { "title": "Pillow covers" } },
        { "type": "category", "settings": { "title": "Cushions" } }
      ]
    }
  ]
}
{% endschema %}
