<section class="section error-404">
  <div class="container error-404__inner">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="error-404__title">{{ section.settings.heading }}</h1>
    {%- if section.settings.text != blank -%}<p class="error-404__text">{{ section.settings.text }}</p>{%- endif -%}
    <a class="btn" href="{{ routes.root_url }}">{{ section.settings.button_label }}</a>
  </div>
</section>

<style>
  .error-404__inner { text-align: center; padding: 60px 0; max-width: 560px; }
  .error-404__title { font-size: clamp(30px, 4vw, 46px); margin: 0 0 14px; }
  .error-404__text { color: var(--muted); margin: 0 0 30px; }
</style>

{% schema %}
{
  "name": "404 page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "404" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Page not found" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "The page you're looking for doesn't exist or has moved." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Continue shopping" }
  ]
}
{% endschema %}
