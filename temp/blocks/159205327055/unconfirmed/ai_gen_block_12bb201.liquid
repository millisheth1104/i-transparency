{% doc %}
  @prompt
    Create a fully responsive Contact Information section exactly like the reference image. The design should be elegant, minimal, and premium.
    
    Layout
    
    Create a 2-column layout.
    
    Left Column (Approx. 65%)
    
    Display an embedded Google Map inside a rounded rectangle.
    
    Requirements:
    
    Use an iframe Google Maps embed.
    Height around 380-420px
    Width: 100%
    Border Radius: 16px
    No border
    Overflow hidden
    Map should completely fill its container.
    The map should be editable through Theme Customizer using a Google Maps Embed URL field.
    If no map URL is entered, show a placeholder with text:
    "Google Map will appear here."
    
    The map should maintain aspect ratio on mobile.
    
    Right Column (Approx. 35%)
    
    Display four information blocks stacked vertically.
    
    Each block contains:
    
    Left:
    
    Outline icon
    
    Right:
    
    Heading
    Content
    
    Spacing should be generous and premium.
    
    Blocks:
    
    Location Pin Icon
    
    Heading:
    Corporate Office
    
    Content:
    Address (multi-line)
    
    Clock Icon
    
    Heading:
    Business Hours
    
    Content:
    Monday to Friday
    10AM – 7PM
    
    Mail Icon
    
    Heading:
    Email ID
    
    Content:
    email@example.com
    
    Should be clickable.
    
    Phone Icon
    
    Heading:
    Contact Number
    
    Content:
    +91 XXXXX XXXXX
    
    Should be clickable.
    
    Styling
    
    Background color:
    Warm off-white
    (#F7F2EA)
    
    Container width:
    1400px max
    
    Padding:
    Top 80px
    Bottom 80px
    Left & Right 40px
    
    Gap between columns:
    70px
    
    Heading "CONTACT"
    
    Small uppercase
    
    Font size:
    14px
    
    Letter spacing:
    4px
    
    Weight:
    500
    
    Color:
    #777
    
    Margin bottom:
    30px
    
    Right Side Headings
    
    Uppercase
    
    Font size:
    15px
    
    Letter spacing:
    4px
    
    Weight:
    600
    
    Color:
    #333
    
    Bottom margin:
    15px
    
    Content
    
    Font size:
    16px
    
    Line height:
    1.8
    
    Color:
    #7B7B7B
    
    Icons
    
    Use Shopify SVG icons or inline SVG.
    
    Icons should be:
    
    Location
    Clock
    Mail
    Phone
    
    Size:
    28px
    
    Color:
    #222
    
    Each icon aligned perfectly with the heading/content.
    
    Keep about 24px spacing between icon and text.
    
    Each information block should have
    
    margin-bottom: 42px
    
    except the last one.
    
    Responsive Behaviour
    
    Desktop
    
    Map left
    
    Contact details right
    
    Tablet
    
    Columns become
    
    55%
    45%
    
    Reduce spacing slightly.
    
    Mobile
    
    Everything stacks vertically.
    
    Map first.
    
    Contact details below.
    
    Map height:
    300px
    
    Contact blocks should have proper spacing.
    
    Icons remain left aligned.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-info-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    width: 100%;
  }

  .ai-contact-info-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-contact-info-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    letter-spacing: {{ block.settings.label_letter_spacing }}px;
    font-weight: {{ block.settings.label_font_weight }};
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    margin-bottom: {{ block.settings.label_margin_bottom }}px;
  }

  .ai-contact-info-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.left_column_width }}% {{ block.settings.right_column_width }}%;
    gap: {{ block.settings.column_gap }}px;
    align-items: start;
  }

  .ai-contact-info-map-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.map_height }}px;
    border-radius: {{ block.settings.map_border_radius }}px;
    overflow: hidden;
    background-color: #e5e5e5;
  }

  .ai-contact-info-map-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .ai-contact-info-map-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    color: #999;
    background-color: #f0f0f0;
  }

  .ai-contact-info-details-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-contact-info-block-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.icon_text_gap }}px;
    margin-bottom: {{ block.settings.block_spacing }}px;
  }

  .ai-contact-info-block-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-contact-info-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-contact-info-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
  }

  .ai-contact-info-text-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-contact-info-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    color: {{ block.settings.heading_color }};
    text-transform: uppercase;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
  }

  .ai-contact-info-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_font_size }}px;
    line-height: {{ block.settings.content_line_height }};
    color: {{ block.settings.content_color }};
    margin: 0;
  }

  .ai-contact-info-content-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ai-contact-info-content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-contact-info-grid-{{ ai_gen_id }} {
      grid-template-columns: 55% 45%;
      gap: 40px;
    }

    .ai-contact-info-{{ ai_gen_id }} {
      padding: 60px 30px;
    }

    .ai-contact-info-map-wrapper-{{ ai_gen_id }} {
      height: 350px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-contact-info-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 50px;
    }

    .ai-contact-info-{{ ai_gen_id }} {
      padding: 50px 20px;
    }

    .ai-contact-info-map-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.map_height_mobile }}px;
    }

    .ai-contact-info-block-{{ ai_gen_id }} {
      margin-bottom: 36px;
    }
  }
{% endstyle %}

<contact-info-{{ ai_gen_id }} class="ai-contact-info-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-info-container-{{ ai_gen_id }}">
    {% if block.settings.section_label != blank %}
      <div class="ai-contact-info-label-{{ ai_gen_id }}">{{ block.settings.section_label }}</div>
    {% endif %}

    <div class="ai-contact-info-grid-{{ ai_gen_id }}">
      <div class="ai-contact-info-map-wrapper-{{ ai_gen_id }}">
        {% if block.settings.google_maps_url != blank %}
          <iframe
            class="ai-contact-info-map-{{ ai_gen_id }}"
            src="{{ block.settings.google_maps_url }}"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Google Maps Location"
          ></iframe>
        {% else %}
          <div class="ai-contact-info-map-placeholder-{{ ai_gen_id }}">
            Google Map will appear here.
          </div>
        {% endif %}
      </div>

      <div class="ai-contact-info-details-{{ ai_gen_id }}">
        {% if block.settings.show_location %}
          <div class="ai-contact-info-block-{{ ai_gen_id }}">
            <div class="ai-contact-info-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div class="ai-contact-info-text-{{ ai_gen_id }}">
              <h3 class="ai-contact-info-heading-{{ ai_gen_id }}">{{ block.settings.location_heading }}</h3>
              <div class="ai-contact-info-content-{{ ai_gen_id }}">{{ block.settings.location_content }}</div>
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_hours %}
          <div class="ai-contact-info-block-{{ ai_gen_id }}">
            <div class="ai-contact-info-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <div class="ai-contact-info-text-{{ ai_gen_id }}">
              <h3 class="ai-contact-info-heading-{{ ai_gen_id }}">{{ block.settings.hours_heading }}</h3>
              <div class="ai-contact-info-content-{{ ai_gen_id }}">{{ block.settings.hours_content }}</div>
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_email %}
          <div class="ai-contact-info-block-{{ ai_gen_id }}">
            <div class="ai-contact-info-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <div class="ai-contact-info-text-{{ ai_gen_id }}">
              <h3 class="ai-contact-info-heading-{{ ai_gen_id }}">{{ block.settings.email_heading }}</h3>
              <div class="ai-contact-info-content-{{ ai_gen_id }}">
                {% if block.settings.email_address != blank %}
                  <a href="mailto:{{ block.settings.email_address }}">{{ block.settings.email_address }}</a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_phone %}
          <div class="ai-contact-info-block-{{ ai_gen_id }}">
            <div class="ai-contact-info-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
            </div>
            <div class="ai-contact-info-text-{{ ai_gen_id }}">
              <h3 class="ai-contact-info-heading-{{ ai_gen_id }}">{{ block.settings.phone_heading }}</h3>
              <div class="ai-contact-info-content-{{ ai_gen_id }}">
                {% if block.settings.phone_number != blank %}
                  <a href="tel:{{ block.settings.phone_number | replace: ' ', '' | replace: '-', '' }}">{{ block.settings.phone_number }}</a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</contact-info-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactInfo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('contact-info-{{ ai_gen_id }}', ContactInfo{{ ai_gen_id }});
  })();
</script>

