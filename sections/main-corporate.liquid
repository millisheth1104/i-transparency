{%- assign s = section.settings -%}
<div class="corp">
  <div class="container">

    {%- comment -%} Hero {%- endcomment -%}
    <section class="corp-hero">
      {%- if s.hero_image != blank -%}
        <img class="corp-hero__bg" src="{{ s.hero_image | image_url: width: 2000 }}" alt="{{ s.hero_heading | strip_html | escape }}" width="1800" height="820" loading="lazy">
      {%- endif -%}
      <div class="corp-hero__inner">
        <p class="eyebrow corp-hero__eyebrow">{{ s.hero_eyebrow }}</p>
        <h1 class="corp-hero__title">{{ s.hero_heading }}</h1>
        {%- if s.hero_button != blank -%}<a class="btn btn--light" href="{{ s.hero_link | default: '#corp-form' }}">{{ s.hero_button }}</a>{%- endif -%}
      </div>
    </section>

    {%- comment -%} Feature strip {%- endcomment -%}
    <section class="corp-strip">
      <div class="corp-strip__item">
        <span class="corp-strip__ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M17.5 13.5 21 17l-3.5 3.5L14 17z"/><path d="M17.5 3.5 21 7l-3.5 3.5L14 7z"/></svg></span>
        <h3 class="corp-strip__t">{{ s.f1_title }}</h3>
        <p class="corp-strip__d">{{ s.f1_text }}</p>
      </div>
      <span class="corp-strip__dot" aria-hidden="true"></span>
      <div class="corp-strip__item">
        <span class="corp-strip__ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M12 3v6"/><path d="m8.5 6.5 3.5-3 3.5 3"/><path d="M5 11h14l-1.5 9h-11z"/></svg></span>
        <h3 class="corp-strip__t">{{ s.f2_title }}</h3>
        <p class="corp-strip__d">{{ s.f2_text }}</p>
      </div>
      <span class="corp-strip__dot" aria-hidden="true"></span>
      <div class="corp-strip__item">
        <span class="corp-strip__ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M2 7h11v9H2z"/><path d="M13 10h4l3 3v3h-7z"/><circle cx="6" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/></svg></span>
        <h3 class="corp-strip__t">{{ s.f3_title }}</h3>
        <p class="corp-strip__d">{{ s.f3_text }}</p>
      </div>
    </section>

    {%- comment -%} Gallery {%- endcomment -%}
    <section class="corp-gallery">
      <div class="corp-gallery__cell g1">{% render 'corp-img', img: s.g1, ph: 'product-1' %}</div>
      <div class="corp-gallery__cell g2">{% render 'corp-img', img: s.g2, ph: 'product-2' %}</div>
      <div class="corp-gallery__cell g3">{% render 'corp-img', img: s.g3, ph: 'lifestyle-1' %}</div>
      <div class="corp-gallery__cell g4 corp-gallery__quote"><p>{{ s.gallery_quote }}</p></div>
      <div class="corp-gallery__cell g5">{% render 'corp-img', img: s.g5, ph: 'lifestyle-2' %}</div>
      <div class="corp-gallery__cell g6">{% render 'corp-img', img: s.g6, ph: 'product-3' %}</div>
    </section>

    {%- comment -%} Experiences {%- endcomment -%}
    <section class="corp-exp">
      <h2 class="corp-exp__title">{{ s.exp_heading }}</h2>
      <div class="corp-exp__items">
        <div class="corp-exp__item">
          <span class="corp-strip__ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M4 13c2-2 4-2 6 0l4 4"/><path d="m12 9 3-3c1.5-1.5 3.5-1.5 5 0s1.5 3.5 0 5l-3 3"/></svg></span>
          <h3 class="corp-strip__t">{{ s.e1_title }}</h3>
          <p class="corp-strip__d">{{ s.e1_text }}</p>
        </div>
        <span class="corp-strip__dot" aria-hidden="true"></span>
        <div class="corp-exp__item">
          <span class="corp-strip__ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="4" y="3" width="16" height="18" rx="1"/><path d="M8 7h3M8 11h3M8 15h3M14 7h2M14 11h2M14 15h2"/></svg></span>
          <h3 class="corp-strip__t">{{ s.e2_title }}</h3>
          <p class="corp-strip__d">{{ s.e2_text }}</p>
        </div>
        <span class="corp-strip__dot" aria-hidden="true"></span>
        <div class="corp-exp__item">
          <span class="corp-strip__ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 21 12 8"/><path d="M14 3s1 3-1 5-5 1-5 1 1-3 3-5 3-1 3-1Z"/><path d="M16 12h.01M19 8h.01M18 15h.01"/></svg></span>
          <h3 class="corp-strip__t">{{ s.e3_title }}</h3>
          <p class="corp-strip__d">{{ s.e3_text }}</p>
        </div>
      </div>
    </section>

    {%- comment -%} Gifting process {%- endcomment -%}
    <section class="corp-process">
      <div class="corp-process__main">
        <p class="eyebrow corp-process__eyebrow">{{ s.process_eyebrow }}</p>
        <h2 class="corp-process__title">{{ s.process_heading }}</h2>
        <div class="corp-process__steps">
          {%- assign steps = 'CONSULT|CURATE|PERSONALISE|DELIVER' | split: '|' -%}
          {%- assign stexts = s.step_texts | split: "
" -%}
          {%- for step in steps -%}
            <div class="corp-step">
              <span class="corp-step__ico" aria-hidden="true">
                {%- case forloop.index -%}
                  {%- when 1 -%}<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="6" y="3" width="12" height="18" rx="2"/><path d="M9 3h6v3H9z"/><path d="M9 11h6M9 15h4"/></svg>
                  {%- when 2 -%}<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M4 11h16v9H4z"/><path d="M4 8h16v3H4z"/><path d="M12 8v12"/><path d="M12 8C9 8 7 6 8 4s4 1 4 4c0-3 2-5 4-4s0 4-4 4Z"/></svg>
                  {%- when 3 -%}<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 12 12 3h6v6l-9 9z"/><circle cx="15" cy="8" r="1.3"/></svg>
                  {%- when 4 -%}<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M2 7h11v9H2z"/><path d="M13 10h4l3 3v3h-7z"/><circle cx="6" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/></svg>
                {%- endcase -%}
              </span>
              <span class="corp-step__num">0{{ forloop.index }}</span>
              <h4 class="corp-step__name">{{ step }}</h4>
              <p class="corp-step__desc">{{ stexts[forloop.index0] }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>
      <div class="corp-process__aside">
        <h3 class="corp-process__aside-t">{{ s.conscious_heading }}</h3>
        <p class="corp-process__aside-d">{{ s.conscious_text }}</p>
      </div>
    </section>

    {%- comment -%} Trusted brands {%- endcomment -%}
    <section class="corp-trust">
      <p class="eyebrow text-center">{{ s.trust_eyebrow }}</p>
      <div class="corp-trust__logos">
        {%- for i in (1..5) -%}
          {%- assign key = 'logo_' | append: i -%}
          {%- assign logo = s[key] -%}
          <div class="corp-trust__logo">
            {%- if logo != blank -%}
              <img src="{{ logo | image_url: width: 240 }}" alt="Brand {{ i }}" width="120" height="60" loading="lazy">
            {%- else -%}
              {{ 'logo' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </section>

    {%- comment -%} Enquiry form {%- endcomment -%}
    <section class="corp-form" id="corp-form">
      <div class="corp-form__intro">
        <h2 class="corp-form__title">{{ s.form_heading }}</h2>
        {%- if s.form_sub != blank -%}<p class="corp-form__sub">{{ s.form_sub }}</p>{%- endif -%}
        <div class="corp-form__media">
          {%- if s.form_image != blank -%}
            <img src="{{ s.form_image | image_url: width: 900 }}" alt="" width="700" height="520" loading="lazy">
          {%- else -%}
            {{ 'product-2' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
      </div>
      <div class="corp-form__fields">
        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <p class="corp-form__ok">Thank you — your enquiry has been sent. Our team will be in touch shortly.</p>
          {%- endif -%}
          {{ form.errors | default_errors }}
          <input type="hidden" name="contact[enquiry_type]" value="Corporate gifting">
          <div class="field field--line">
            <label for="cg-name">Full Name</label>
            <input type="text" id="cg-name" name="contact[name]" placeholder="First and last name" required>
          </div>
          <div class="field field--line">
            <label for="cg-email">Email Address</label>
            <input type="email" id="cg-email" name="contact[email]" placeholder="joe@gmail.com" value="{{ customer.email }}" required>
          </div>
          <div class="field field--line">
            <label for="cg-phone">Phone Number</label>
            <input type="tel" id="cg-phone" name="contact[phone]" placeholder="+91">
          </div>
          <div class="field field--line">
            <label for="cg-msg">Message</label>
            <textarea id="cg-msg" name="contact[body]" rows="3" placeholder="Tell us more about your enquiry"></textarea>
          </div>
          <button type="submit" class="btn btn--block">Submit Enquiry</button>
        {%- endform -%}
      </div>
    </section>

  </div>
</div>

<style>
  .corp { padding: 30px 0 90px; }
  .corp section { margin-bottom: 90px; }

  /* Hero */
  .corp-hero { position: relative; border-radius: var(--radius-lg); overflow: hidden; background: var(--olive); min-height: 560px; display: flex; }
  .corp-hero__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .corp-hero__bg::after { content: ""; }
  .corp-hero__inner { position: relative; z-index: 1; padding: 70px; max-width: 620px; align-self: center; background: linear-gradient(90deg, rgba(60,60,45,.72) 0%, rgba(60,60,45,.45) 70%, transparent 100%); }
  .corp-hero::before { content: ""; position: absolute; inset: 0; background: rgba(50,50,38,.35); z-index: 0; }
  .corp-hero__eyebrow { color: rgba(244,238,228,.85); letter-spacing: .24em; }
  .corp-hero__title { color: var(--cream); font-size: clamp(38px, 5vw, 62px); line-height: 1.08; margin: 0 0 34px; }
  .corp-hero__title em { font-style: italic; }

  /* Feature strip */
  .corp-strip { background: var(--sand); border-radius: var(--radius-lg); padding: 46px 40px; display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; align-items: center; gap: 20px; text-align: center; }
  .corp-strip__ico { color: var(--brown); display: inline-flex; margin-bottom: 14px; }
  .corp-strip__t { font-family: var(--font-sans); font-weight: 400; font-size: 13px; letter-spacing: .18em; text-transform: uppercase; color: var(--brown); margin: 0 0 8px; }
  .corp-strip__d { color: var(--brown-2); margin: 0 auto; max-width: 26ch; font-size: 14px; }
  .corp-strip__dot { width: 5px; height: 5px; border-radius: 50%; background: var(--brown); opacity: .5; }

  /* Gallery */
  .corp-gallery { display: grid; grid-template-columns: 1fr 1.2fr 1.8fr; grid-auto-rows: 200px; gap: 18px; }
  .corp-gallery__cell { border-radius: var(--radius); overflow: hidden; background: var(--cream-2); }
  .corp-gallery__cell img, .corp-gallery__cell svg { width: 100%; height: 100%; object-fit: cover; }
  .corp-gallery__quote { background: var(--sand); display: flex; align-items: center; padding: 28px; }
  .corp-gallery__quote p { font-family: var(--font-serif); font-size: 24px; line-height: 1.25; color: var(--brown); margin: 0; }

  /* Experiences */
  .corp-exp { display: grid; grid-template-columns: 1fr 1.6fr; gap: 40px; align-items: center; background: var(--cream-2); border-radius: var(--radius-lg); padding: 44px; }
  .corp-exp__title { font-size: clamp(26px, 3vw, 34px); }
  .corp-exp__title em { font-style: italic; }
  .corp-exp__items { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; align-items: start; gap: 16px; text-align: center; }
  .corp-exp__item .corp-strip__d { max-width: 22ch; }

  /* Process */
  .corp-process { background: var(--olive); border-radius: var(--radius-lg); padding: 54px; display: grid; grid-template-columns: 1.9fr 1fr; gap: 40px; color: var(--cream); }
  .corp-process__eyebrow { color: rgba(244,238,228,.7); }
  .corp-process__title { color: var(--cream); font-size: clamp(28px, 3.2vw, 40px); margin-bottom: 44px; }
  .corp-process__steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .corp-step { text-align: center; }
  .corp-step__ico { width: 62px; height: 62px; border-radius: 50%; background: var(--sand); color: var(--brown); display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px; }
  .corp-step__num { display: block; font-size: 13px; letter-spacing: .1em; color: rgba(244,238,228,.7); margin-bottom: 6px; }
  .corp-step__name { font-family: var(--font-sans); font-weight: 400; font-size: 12px; letter-spacing: .18em; text-transform: uppercase; color: var(--cream); margin: 0 0 8px; }
  .corp-step__desc { font-size: 13px; color: rgba(244,238,228,.75); margin: 0; }
  .corp-process__aside { border: 1px solid rgba(244,238,228,.3); border-radius: var(--radius); padding: 30px; align-self: stretch; }
  .corp-process__aside-t { font-family: var(--font-serif); font-size: 24px; color: var(--cream); margin: 0 0 14px; }
  .corp-process__aside-d { font-size: 14px; color: rgba(244,238,228,.78); margin: 0; }

  /* Trust */
  .corp-trust__logos { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 20px; margin-top: 26px; }
  .corp-trust__logo { width: 120px; height: 72px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.5); border-radius: var(--radius); opacity: .75; padding: 12px; }
  .corp-trust__logo img { max-height: 100%; width: auto; object-fit: contain; }

  /* Form */
  .corp-form { display: grid; grid-template-columns: 1fr 1.1fr; gap: 60px; align-items: start; margin-bottom: 0; }
  .corp-form__title { font-size: clamp(34px, 4.4vw, 52px); }
  .corp-form__sub { color: var(--muted); margin: 16px 0 0; max-width: 42ch; }
  .corp-form__media { margin-top: 40px; border-radius: var(--radius); overflow: hidden; }
  .corp-form__media img, .corp-form__media svg { width: 100%; object-fit: contain; }
  .corp-form__ok { background: var(--cream-2); border-radius: 8px; padding: 14px 18px; color: var(--brown); margin: 0 0 20px; }
  .corp-form .field--line label { color: var(--brown); }
  .corp-form .field--line input, .corp-form .field--line textarea { border: none; border-bottom: 1px solid var(--line); border-radius: 0; padding: 10px 0; background: transparent; }
  .corp-form .field--line input:focus, .corp-form .field--line textarea:focus { border-bottom-color: var(--taupe); }
  .corp-form .btn { margin-top: 14px; }

  @media (max-width: 990px) {
    .corp-gallery { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 860px) {
    .corp section { margin-bottom: 60px; }
    .corp-strip, .corp-exp__items { grid-template-columns: 1fr; gap: 26px; }
    .corp-strip__dot, .corp-exp__items .corp-strip__dot { display: none; }
    .corp-exp { grid-template-columns: 1fr; }
    .corp-process { grid-template-columns: 1fr; padding: 34px; }
    .corp-process__steps { grid-template-columns: 1fr 1fr; }
    .corp-hero__inner { padding: 40px 30px; }
    .corp-form { grid-template-columns: 1fr; gap: 34px; }
  }
</style>

{% schema %}
{
  "name": "Corporate page",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Crafted with care · Wrapped in elegance" },
    { "type": "inline_richtext", "id": "hero_heading", "label": "Heading", "default": "Thoughtful gifts that leave a <em>lasting impression</em>" },
    { "type": "text", "id": "hero_button", "label": "Button label", "default": "Enquire now" },
    { "type": "url", "id": "hero_link", "label": "Button link" },
    { "type": "header", "content": "Feature strip" },
    { "type": "text", "id": "f1_title", "label": "Feature 1 title", "default": "Bulk Orders" },
    { "type": "text", "id": "f1_text", "label": "Feature 1 text", "default": "Flexible solutions for every business and occasion." },
    { "type": "text", "id": "f2_title", "label": "Feature 2 title", "default": "Customisation" },
    { "type": "text", "id": "f2_text", "label": "Feature 2 text", "default": "Personalised messages that reflect your identity." },
    { "type": "text", "id": "f3_title", "label": "Feature 3 title", "default": "Pan India Delivery" },
    { "type": "text", "id": "f3_text", "label": "Feature 3 text", "default": "Reliable delivery with careful handling and on-time assurance." },
    { "type": "header", "content": "Gallery" },
    { "type": "image_picker", "id": "g1", "label": "Image 1" },
    { "type": "image_picker", "id": "g2", "label": "Image 2" },
    { "type": "image_picker", "id": "g3", "label": "Image 3 (large)" },
    { "type": "text", "id": "gallery_quote", "label": "Quote tile", "default": "Thoughtfully crafted for spaces that inspire." },
    { "type": "image_picker", "id": "g5", "label": "Image 5" },
    { "type": "image_picker", "id": "g6", "label": "Image 6 (large)" },
    { "type": "header", "content": "Experiences" },
    { "type": "inline_richtext", "id": "exp_heading", "label": "Heading", "default": "Create <em>meaningful experiences</em> for every occasion" },
    { "type": "text", "id": "e1_title", "label": "Item 1 title", "default": "Client Relations" },
    { "type": "text", "id": "e1_text", "label": "Item 1 text", "default": "Thoughtful curations that strengthen bonds." },
    { "type": "text", "id": "e2_title", "label": "Item 2 title", "default": "Events" },
    { "type": "text", "id": "e2_text", "label": "Item 2 text", "default": "Welcome kits that make an impact." },
    { "type": "text", "id": "e3_title", "label": "Item 3 title", "default": "Celebrations" },
    { "type": "text", "id": "e3_text", "label": "Item 3 text", "default": "Elegant gifting for special moments." },
    { "type": "header", "content": "Gifting process" },
    { "type": "text", "id": "process_eyebrow", "label": "Eyebrow", "default": "Our Gifting Process" },
    { "type": "text", "id": "process_heading", "label": "Heading", "default": "Seamless from start to thoughtful delivery." },
    { "type": "textarea", "id": "step_texts", "label": "Step descriptions (one per line)", "default": "Share your requirements and occasion with us.\nWe create a customised proposal and options.\nAdd your branding, messages and packaging.\nWe deliver with care, on time, every time." },
    { "type": "text", "id": "conscious_heading", "label": "Aside heading", "default": "Conscious gifting for a better tomorrow." },
    { "type": "textarea", "id": "conscious_text", "label": "Aside text", "default": "Our packaging is plastic-free and recyclable. Because every thoughtful gift should be kind to the planet." },
    { "type": "header", "content": "Trusted brands" },
    { "type": "text", "id": "trust_eyebrow", "label": "Eyebrow", "default": "Trusted by leading brands" },
    { "type": "image_picker", "id": "logo_1", "label": "Logo 1" },
    { "type": "image_picker", "id": "logo_2", "label": "Logo 2" },
    { "type": "image_picker", "id": "logo_3", "label": "Logo 3" },
    { "type": "image_picker", "id": "logo_4", "label": "Logo 4" },
    { "type": "image_picker", "id": "logo_5", "label": "Logo 5" },
    { "type": "header", "content": "Enquiry form" },
    { "type": "text", "id": "form_heading", "label": "Heading", "default": "Enquire about corporate gifting" },
    { "type": "text", "id": "form_sub", "label": "Sub text", "default": "Share your requirements and our team will get in touch with you to create a solution that fits your needs." },
    { "type": "image_picker", "id": "form_image", "label": "Form image" }
  ],
  "presets": [{ "name": "Corporate page" }]
}
{% endschema %}
