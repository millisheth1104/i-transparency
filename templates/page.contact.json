      "settings": {
        "custom_liquid": "<div class=\"contact-section\">\n\n  <!-- TOP SECTION -->\n  <div class=\"contact-top\">\n\n    <p class=\"contact-label\">CONTACT</p>\n\n    <div class=\"contact-map-info\">\n\n      <div class=\"map-embed\">\n        <iframe\n          src=\"https://www.google.com/maps?q=Thakor+Industrial+Estate,+Premier+Road,+Khalaj+Village,+Vidyavihar+West,+Mumbai,+Maharashtra+400086&output=embed\"\n          loading=\"lazy\"\n          allowfullscreen\n          width=\"100%\"\n          height=\"400\"\n          style=\"border:0;\">\n        </iframe>\n      </div>\n\n      <div class=\"office-info\">\n\n        <div class=\"info-block\">\n          <strong>CORPORATE OFFICE</strong>\n          <p>\n            Thakor Industrial Estate,\n            Premier Road,\n            Khalaj Village,\n            Vidyavihar West,\n            Mumbai,\n            Maharashtra 400086\n          </p>\n        </div>\n\n        <div class=\"info-block\">\n          <strong>BUSINESS HOURS</strong>\n          <p>Monday to Friday<br>10AM – 7PM</p>\n        </div>\n\n        <div class=\"info-block\">\n          <strong>EMAIL ID</strong>\n          <p><a href=\"mailto:info@sarom.com\">info@sarom.com</a></p>\n        </div>\n\n        <div class=\"info-block\">\n          <strong>CONTACT NUMBER</strong>\n          <p><a href=\"tel:0828911111\">08289 11111</a></p>\n        </div>\n\n      </div>\n\n    </div>\n\n  </div>\n\n  <!-- CONTACT FORM -->\n\n  <div class=\"contact-bottom\">\n\n    <div class=\"contact-left\">\n\n      <div class=\"contact-text\">\n        <h2>Have a question?</h2>\n\n        <p>\n          Write to us and we'll get back to you as soon as possible.\n        </p>\n      </div>\n\n      <div class=\"contact-image\">\n        <img\n  src=\"{{ '24cf3d05a7654dc39c3dd40ca14c5effd5bd116f.png' | asset_url }}\"\n  alt=\"Contact image\"\n  width=\"420\"\n  height=\"auto\">\n      </div>\n\n    </div>\n\n    <div class=\"contact-right\">\n\n      {% form 'contact', id: 'ContactForm' %}\n\n        {% if form.posted_successfully? %}\n          <p class=\"form-success\">\n            Thanks! We'll be in touch soon.\n          </p>\n        {% endif %}\n\n        <label>FULL NAME</label>\n        <input\n          type=\"text\"\n          name=\"contact[name]\"\n          placeholder=\"First and last name\"\n          required>\n\n        <label>EMAIL ADDRESS</label>\n        <input\n          type=\"email\"\n          name=\"contact[email]\"\n          placeholder=\"joe@gmail.com\"\n          required>\n\n        <label>PHONE NUMBER</label>\n        <input\n          type=\"tel\"\n          name=\"contact[phone]\"\n          placeholder=\"+91\">\n\n        <label>MESSAGE</label>\n        <textarea\n          name=\"contact[body]\"\n          placeholder=\"Tell us more about your enquiry\"\n          ></textarea>\n\n        <button type=\"submit\">\n          SUBMIT ENQUIRY\n        </button>\n\n      {% endform %}\n\n    </div>\n\n  </div>\n\n</div>\n\n<style>\n\n.contact-section{\n    max-width:1400px;\n    margin:auto;\n    padding:80px 40px;\n    background:#F7F2EA;\n    color:#5d534c;\n}\n\n/* ---------- TOP SECTION ---------- */\n\n.contact-label{\n    font-size:13px;\n    letter-spacing:4px;\n    text-transform:uppercase;\n    color:#777;\n    margin-bottom:35px;\n}\n\n.contact-map-info{\n    display:flex;\n    justify-content:space-between;\n    gap:70px;\n    margin-bottom:90px;\n}\n\n.map-embed{\n    flex:0 0 62%;\n}\n\n.map-embed iframe{\n    width:100%;\n    height:400px;\n    border-radius:18px;\n}\n\n.office-info{\n    flex:0 0 38%;\n}\n\n.info-block{\n    margin-bottom:42px;\n}\n\n.info-block:last-child{\n    margin-bottom:0;\n}\n\n.info-block strong{\n    display:block;\n    font-size:13px;\n    letter-spacing:3px;\n    font-weight:600;\n    margin-bottom:12px;\n}\n\n.info-block p,\n.info-block a{\n    color:#777;\n    line-height:1.8;\n    text-decoration:none;\n}\n\n/* ---------- BOTTOM SECTION ---------- */\n\n.contact-bottom{\n    display:flex;\n    justify-content:space-between;\n    align-items:flex-start;\n    gap:90px;\n}\n\n.contact-left{\n    flex:0 0 42%;\n    display:flex;\n    flex-direction:column;\n}\n\n.contact-right{\n    flex:0 0 58%;\n}\n\n.contact-text{\n    margin-bottom:70px;\n}\n\n.contact-left h2{\n    font-family:Georgia, serif;\n    font-size:60px;\n    font-weight:400;\n    line-height:1.05;\n    margin:0 0 22px;\n    color:#5d534c;\n}\n\n.contact-left p{\n    font-size:20px;\n    color:#8b8178;\n    line-height:1.8;\n    max-width:420px;\n    margin:0;\n}\n\n.contact-image{\n    margin-top:auto;\n}\n\n.contact-image img{\n    width:100%;\n    max-width:420px;\n    display:block;\n}\n\n/* ---------- FORM ---------- */\n\n.contact-right label{\n    display:block;\n    font-size:13px;\n    letter-spacing:3px;\n    font-weight:600;\n    margin-bottom:10px;\n    margin-top:34px;\n}\n\n.contact-right label:first-child{\n    margin-top:0;\n}\n\n.contact-right input,\n.contact-right textarea{\n    width:100%;\n    border:none;\n    border-bottom:1px solid #7b7269;\n    background:transparent;\n    padding:16px 0;\n    font-size:16px;\n    outline:none;\n}\n\n.contact-right input::placeholder,\n.contact-right textarea::placeholder{\n    color:#aaa;\n}\n\n.contact-right textarea{\n    resize:none;\n}\n\n.contact-right button{\n    width:100%;\n    margin-top:45px;\n    height:60px;\n    border:none;\n    background:#5c5148;\n    color:#fff;\n    letter-spacing:3px;\n    text-transform:uppercase;\n    cursor:pointer;\n    transition:.3s;\n    font-size:14px;\n}\n\n.contact-right button:hover{\n    background:#443b34;\n}\n\n.form-success{\n    color:green;\n    margin-bottom:20px;\n}\n\n/* ---------- RESPONSIVE ---------- */\n\n@media(max-width:991px){\n\n.contact-map-info{\n    flex-direction:column;\n}\n\n.contact-bottom{\n    flex-direction:column;\n    gap:60px;\n}\n\n.contact-left,\n.contact-right{\n    width:100%;\n    flex:100%;\n}\n\n.contact-left h2{\n    font-size:42px;\n}\n\n.contact-left p{\n    font-size:18px;\n}\n\n.contact-image{\n    margin-top:40px;\n}\n\n.contact-image img{\n    max-width:320px;\n}\n\n.map-embed iframe{\n    height:320px;\n}\n\n.contact-section{\n    padding:60px 20px;\n}\n\n}\n/* Remove space added by Horizon section wrapper */\n.shopify-section {\n    margin: 0 !important;\n    padding: 0 !important;\n}\n\n.shopify-section .page-width {\n    margin-top: 0 !important;\n    padding-top: 0 !important;\n}\n\n.contact-section {\n    margin-top: 0 !important;\n    padding-top: 0 !important;\n}\n\n</style>",
