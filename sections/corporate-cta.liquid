<section class="section corporate-cta">
  <div class="container">
    <div class="cta-band">
      <div class="cta-band__media">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.heading | escape }}" width="1200" height="800" loading="lazy">
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag }}
        {%- endif -%}
      </div>
      <div class="cta-band__body">
        <p class="eyebrow cta-band__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- if section.settings.text != blank -%}<p class="cta-band__text">{{ section.settings.text }}</p>{%- endif -%}
        <div class="cta-band__actions">
          {%- if section.settings.button_label_1 != blank -%}<a class="btn btn--gold" href="{{ section.settings.button_link_1 }}">{{ section.settings.button_label_1 }}</a>{%- endif -%}
          {%- if section.settings.button_label_2 != blank -%}<a class="btn btn--light" href="{{ section.settings.button_link_2 }}">{{ section.settings.button_label_2 }}</a>{%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .corporate-cta { padding: 0; }
  .cta-band { display: grid; grid-template-columns: 637px 1fr; background: var(--olive); border-radius: 0; overflow: hidden; align-items: center; width: 1152px; max-width: 100%; height: 284px; margin: 0 auto; }
  .cta-band__media { padding: 22px; }
  .cta-band__media img, .cta-band__media svg { width: 593px; height: 240px; max-width: 100%; object-fit: cover; border-radius: 0; }
  .cta-band__body { padding: 50px 60px; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .cta-band__eyebrow { color: var(--gold); letter-spacing: .2em; }
  .cta-band__text { color: rgba(244,238,228,.75); max-width: 46ch; margin: 0 0 30px; }
  .cta-band__actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 16px; }
  @media (max-width: 860px){ .cta-band { grid-template-columns: 1fr; width: 100%; height: auto; } .cta-band__media img, .cta-band__media svg { width: 100%; height: auto; aspect-ratio: 593/240; } .cta-band__body { padding: 10px 34px 44px; } }
</style>

{% schema %}
{
  "name": "Corporate CTA",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Corporate & Bulk Orders" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Premium knitted-cotton bedding for hotels, resorts, designers, architects and developers — with trade pricing, custom shades and reliable supply." },
    { "type": "text", "id": "button_label_1", "label": "Button 1 label", "default": "Request a quote" },
    { "type": "url", "id": "button_link_1", "label": "Button 1 link" },
    { "type": "text", "id": "button_label_2", "label": "Button 2 label", "default": "Enquire now" },
    { "type": "url", "id": "button_link_2", "label": "Button 2 link" }
  ],
  "presets": [{ "name": "Corporate CTA" }]
}
{% endschema %}
