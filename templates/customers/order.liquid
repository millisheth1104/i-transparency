<div class="orderd container">
  <p class="orderd__crumb">Profile / Orders</p>

  <div class="orderd__layout">
    <nav class="orderd__nav" aria-label="Account">
      <a class="orderd__nav-item" href="{{ routes.account_url }}#details">My Details</a>
      <a class="orderd__nav-item is-active" href="{{ routes.account_url }}#orders">Orders</a>
    </nav>

    <div class="orderd__main">
      <div class="orderd__head">
        <h1 class="orderd__num">Order Number <span>#{{ order.name | remove: '#' }}</span></h1>
        <div class="orderd__links">
          <a href="{{ order.order_status_url | default: order.customer_url }}">Download Invoice</a>
          <a href="{{ order.order_status_url | default: order.customer_url }}">Download Receipt</a>
        </div>
      </div>

      <p class="orderd__meta">{{ order.item_count }} item(s)</p>
      <p class="orderd__meta">Order value: {{ order.total_price | money }}</p>
      <p class="orderd__meta">Order date: {{ order.created_at | date: '%d/%m/%Y' }}</p>
      <p class="orderd__meta">Payment status: {{ order.financial_status_label }}</p>

      <hr class="orderd__rule">

      {%- assign ship = order.shipping_address -%}
      <div class="orderd__field">
        <p class="orderd__label">Full Name</p>
        <p class="orderd__value">{{ ship.name | default: order.customer.name | default: order.name }}</p>
      </div>
      <div class="orderd__field">
        <p class="orderd__label">Email ID</p>
        <p class="orderd__value">{{ order.email | default: order.customer.email }}</p>
      </div>
      <div class="orderd__field">
        <p class="orderd__label">Phone Number</p>
        <p class="orderd__value">{{ ship.phone | default: order.customer.phone | default: '—' }}</p>
      </div>
      <div class="orderd__field">
        <p class="orderd__label">Address</p>
        <p class="orderd__value">{%- if ship -%}{{ ship | format_address }}{%- else -%}—{%- endif -%}</p>
      </div>

      <hr class="orderd__rule">

      {%- comment -%} Line items {%- endcomment -%}
      <div class="orderd__items">
        {%- for line in order.line_items -%}
          <div class="orderd__item">
            <div class="orderd__item-media">
              {%- if line.image -%}
                <img src="{{ line.image | image_url: width: 160 }}" alt="{{ line.title | escape }}" width="80" height="100" loading="lazy">
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag }}
              {%- endif -%}
            </div>
            <div class="orderd__item-body">
              <p class="orderd__item-title">{{ line.product.title | default: line.title }}</p>
              {%- unless line.variant.title contains 'Default' -%}<p class="orderd__item-variant">{{ line.variant.title }}</p>{%- endunless -%}
              <p class="orderd__item-qty">Qty {{ line.quantity }}</p>
            </div>
            <span class="orderd__item-price">{{ line.final_line_price | money }}</span>
          </div>
        {%- endfor -%}
      </div>

      <hr class="orderd__rule">

      {%- assign fs = order.fulfillment_status -%}
      <div class="orderd__banner">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="m8.5 12 2.5 2.5 4.5-5"/></svg>
        <span>
          {%- if fs == 'fulfilled' -%}Your order has been delivered
          {%- elsif fs == 'partial' -%}Your order is partially on its way
          {%- else -%}Your order is being prepared{%- endif -%}
        </span>
      </div>
      <p class="orderd__status">Status: {{ order.fulfillment_status_label | default: 'In progress' }}</p>
      {%- if fs == 'fulfilled' -%}
        <p class="orderd__status">Delivered on: {{ order.line_items.first.fulfillment.created_at | date: '%d/%m/%Y' }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .orderd { padding: 40px 0 90px; }
  .orderd__crumb { font-size: 12px; letter-spacing: .18em; text-transform: uppercase; color: var(--brown); margin: 0 0 40px; }
  .orderd__layout { display: grid; grid-template-columns: 230px 1fr; gap: 60px; align-items: start; }
  .orderd__nav { display: flex; flex-direction: column; gap: 6px; }
  .orderd__nav-item { padding: 14px 20px; font-family: var(--font-serif); font-size: 20px; color: var(--muted); border-radius: 8px; border-left: 2px solid transparent; }
  .orderd__nav-item.is-active { background: var(--cream-2); color: var(--brown); border-left-color: var(--taupe); }

  .orderd__main { max-width: 760px; }
  .orderd__head { display: flex; align-items: center; justify-content: space-between; gap: 20px; margin-bottom: 16px; }
  .orderd__num { font-family: var(--font-ui); font-weight: 400; font-size: 22px; letter-spacing: .12em; text-transform: uppercase; color: var(--brown); margin: 0; }
  .orderd__num span { text-decoration: underline; text-underline-offset: 4px; }
  .orderd__links { display: flex; gap: 24px; }
  .orderd__links a { color: var(--brown); text-decoration: underline; text-underline-offset: 3px; font-size: 15px; }
  .orderd__meta { color: var(--muted); margin: 0 0 8px; }
  .orderd__rule { border: none; border-top: 1px solid var(--line); margin: 32px 0; }
  .orderd__field { margin-bottom: 26px; }
  .orderd__label { font-size: 12px; letter-spacing: .18em; text-transform: uppercase; color: var(--brown); margin: 0 0 10px; }
  .orderd__value { color: var(--muted); margin: 0; }

  .orderd__item { display: flex; align-items: center; gap: 18px; padding: 12px 0; }
  .orderd__item-media { width: 64px; height: 80px; flex: none; border-radius: 8px; overflow: hidden; background: var(--cream-2); }
  .orderd__item-media img, .orderd__item-media svg { width: 100%; height: 100%; object-fit: cover; }
  .orderd__item-body { flex: 1; }
  .orderd__item-title { color: var(--brown); margin: 0 0 4px; }
  .orderd__item-variant, .orderd__item-qty { color: var(--muted); font-size: 14px; margin: 0; }
  .orderd__item-price { color: var(--brown); font-weight: 500; }

  .orderd__banner { display: flex; align-items: center; justify-content: center; gap: 12px; background: var(--taupe-dark); color: var(--cream); border-radius: 999px; padding: 18px 28px; font-family: var(--font-serif); font-style: italic; font-size: 19px; }
  .orderd__status { color: var(--muted); margin: 18px 0 0; }

  @media (max-width: 860px) {
    .orderd__layout { grid-template-columns: 1fr; gap: 30px; }
    .orderd__nav { flex-direction: row; }
    .orderd__head { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
