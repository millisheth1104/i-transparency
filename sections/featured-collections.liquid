<section class="section featured-band">
  <div class="container">
    <p class="eyebrow text-center fc__eyebrow">{{ section.settings.eyebrow }}</p>

    <div class="fc__track" data-fc-track style="height: {{ section.blocks.size | times: 90 }}vh;">
      <div class="fc__pin" data-fc-pin>
        <div class="fc" data-fc>
          <div class="fc__dots">
            {%- for block in section.blocks -%}
              <button class="fc__dot {% if forloop.first %}is-active{% endif %}" data-fc-dot="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
            {%- endfor -%}
          </div>

          <div class="fc__stage">
            {%- for block in section.blocks -%}
              <a href="{{ block.settings.link }}" class="fc__slide {% if forloop.first %}is-active{% endif %}" data-fc-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 1600 }}" alt="{{ block.settings.title | escape }}" width="1600" height="1000" loading="lazy">
                {%- else -%}
                  {{ 'lifestyle-2' | placeholder_svg_tag }}
                {%- endif -%}
                <span class="fc__slide-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}/</span>
                <span class="fc__slide-title">{{ block.settings.title }}</span>
              </a>
            {%- endfor -%}
          </div>

          <div class="fc__list">
            {%- for block in section.blocks -%}
              <button class="fc__item {% if forloop.first %}is-active{% endif %}" data-fc-item="{{ forloop.index0 }}">
                <span class="fc__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}/</span>
                <span class="fc__name">{{ block.settings.title }}</span>
              </button>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .featured-band { background: var(--cream-2); border-radius: var(--radius-lg); margin: 0 var(--gutter); }
  .fc__track { position: relative; }
  .fc__pin { width: 100%; min-height: 100vh; display: flex; align-items: center; position: absolute; top: 0; left: 0; }
  .fc__pin.is-fixed { position: fixed; top: 0; left: 0; }
  .fc__pin.is-bottom { position: absolute; top: auto; bottom: 0; }
  .fc { display: grid; grid-template-columns: 40px 812px 300px; gap: 24px; align-items: center; margin-top: 30px; width: 1200px; max-width: 100%; margin-left: auto; margin-right: auto; }
  .fc__dots { display: flex; flex-direction: column; gap: 16px; }
  .fc__dot { width: 9px; height: 9px; border-radius: 50%; border: 1px solid var(--taupe); background: transparent; padding: 0; }
  .fc__dot.is-active { background: var(--brown); border-color: var(--brown); }
  .fc__stage { position: relative; border-radius: var(--radius); overflow: hidden; width: 100%; height: 516px; }
  .fc__slide { position: absolute; inset: 0; opacity: 0; transition: opacity .5s; pointer-events: none; }
  .fc__slide.is-active { opacity: 1; pointer-events: auto; }
  .fc__slide img, .fc__slide svg { width: 100%; height: 100%; object-fit: cover; }
  .fc__slide-num { position: absolute; top: 28px; left: 34px; color: var(--brown-2); font-size: 13px; letter-spacing: .1em; z-index: 1; }
  .fc__slide-title { position: absolute; top: 50px; left: 34px; color: var(--brown); font-size: 34px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; z-index: 1; }
  .fc__list { display: flex; flex-direction: column; gap: 26px; }
  .fc__item { background: none; border: none; text-align: left; padding: 0; display: flex; flex-direction: column; gap: 4px; opacity: .45; transition: opacity .25s; }
  .fc__item.is-active { opacity: 1; }
  .fc__num { font-size: 12px; letter-spacing: .1em; color: var(--taupe); }
  .fc__name { font-size: 22px; letter-spacing: .16em; text-transform: uppercase; color: var(--brown); }
  @media (max-width: 860px){ .featured-band { margin: 0; border-radius: 0; } .fc { grid-template-columns: 1fr; width: 100%; } .fc__stage { height: auto; aspect-ratio: 812 / 516; } .fc__dots { flex-direction: row; } .fc__list { flex-direction: row; flex-wrap: wrap; gap: 16px 30px; } }

  /* Scroll-scrub relies on a tall track + a JS-managed pin; skip it for reduced motion so the section behaves like a normal in-flow block. */
  @media (prefers-reduced-motion: reduce) {
    .fc__track { height: auto !important; }
    .fc__pin { position: static !important; min-height: 0; }
  }

  /* Scroll-triggered reveal (Intersection Observer adds .is-revealed once, no repeat). */
  .fc__eyebrow { opacity: 0; transform: translateY(16px); transition: opacity .6s cubic-bezier(.22,1,.36,1), transform .6s cubic-bezier(.22,1,.36,1); }
  .fc.is-revealed .fc__eyebrow { opacity: 1; transform: translateY(0); }

  .fc__stage { opacity: 0; transform: scale(.96) translateY(40px); box-shadow: 0 0 0 rgba(40,32,24,0); transition: opacity .6s cubic-bezier(.22,1,.36,1), transform .6s cubic-bezier(.22,1,.36,1), box-shadow .6s cubic-bezier(.22,1,.36,1); }
  .fc.is-revealed .fc__stage { opacity: 1; transform: scale(1) translateY(0); box-shadow: 0 20px 46px rgba(40,32,24,.16); }

  /* Dots slide in from the right with a slight stagger, same as the list. */
  .fc__dots { opacity: 0; transform: translateX(20px); transition: opacity .5s cubic-bezier(.22,1,.36,1), transform .5s cubic-bezier(.22,1,.36,1); transition-delay: .1s; }
  .fc.is-revealed .fc__dots { opacity: 1; transform: translateX(0); }

  .fc:not(.is-revealed) .fc__item { opacity: 0 !important; }
  .fc__item { transform: translateX(30px); transition: opacity .5s cubic-bezier(.22,1,.36,1), transform .6s cubic-bezier(.22,1,.36,1); }
  .fc.is-revealed .fc__item { transform: translateX(0); }
  .fc__num, .fc__name { display: inline-block; transform: translateY(10px); opacity: 0; transition: opacity .5s cubic-bezier(.22,1,.36,1), transform .5s cubic-bezier(.22,1,.36,1); }
  .fc.is-revealed .fc__num, .fc.is-revealed .fc__name { opacity: 1; transform: translateY(0); }

  /* Per-item stagger (0.12s apart), plus a small extra offset on the title
     relative to its own number, per block position (up to 8 blocks). */
  .fc__item:nth-child(1) { transition-delay: .15s; } .fc__item:nth-child(1) .fc__num { transition-delay: .15s; } .fc__item:nth-child(1) .fc__name { transition-delay: .23s; }
  .fc__item:nth-child(2) { transition-delay: .27s; } .fc__item:nth-child(2) .fc__num { transition-delay: .27s; } .fc__item:nth-child(2) .fc__name { transition-delay: .35s; }
  .fc__item:nth-child(3) { transition-delay: .39s; } .fc__item:nth-child(3) .fc__num { transition-delay: .39s; } .fc__item:nth-child(3) .fc__name { transition-delay: .47s; }
  .fc__item:nth-child(4) { transition-delay: .51s; } .fc__item:nth-child(4) .fc__num { transition-delay: .51s; } .fc__item:nth-child(4) .fc__name { transition-delay: .59s; }
  .fc__item:nth-child(5) { transition-delay: .63s; } .fc__item:nth-child(5) .fc__num { transition-delay: .63s; } .fc__item:nth-child(5) .fc__name { transition-delay: .71s; }
  .fc__item:nth-child(6) { transition-delay: .75s; } .fc__item:nth-child(6) .fc__num { transition-delay: .75s; } .fc__item:nth-child(6) .fc__name { transition-delay: .83s; }
  .fc__item:nth-child(7) { transition-delay: .87s; } .fc__item:nth-child(7) .fc__num { transition-delay: .87s; } .fc__item:nth-child(7) .fc__name { transition-delay: .95s; }
  .fc__item:nth-child(8) { transition-delay: .99s; } .fc__item:nth-child(8) .fc__num { transition-delay: .99s; } .fc__item:nth-child(8) .fc__name { transition-delay: 1.07s; }

  @media (prefers-reduced-motion: reduce) {
    .fc__eyebrow, .fc__stage, .fc__dots, .fc__item, .fc__num, .fc__name { transition: none !important; opacity: 1 !important; transform: none !important; }
  }
</style>

<script>
  document.querySelectorAll('[data-fc]').forEach(function(root){
    if (root.dataset.fcInit) return;
    root.dataset.fcInit = '1';
    function go(i){
      root.querySelectorAll('[data-fc-slide]').forEach(function(s){ s.classList.toggle('is-active', s.dataset.fcSlide==i); });
      root.querySelectorAll('[data-fc-item]').forEach(function(s){ s.classList.toggle('is-active', s.dataset.fcItem==i); });
      root.querySelectorAll('[data-fc-dot]').forEach(function(s){ s.classList.toggle('is-active', s.dataset.fcDot==i); });
    }
    root.querySelectorAll('[data-fc-item],[data-fc-dot]').forEach(function(el){
      el.addEventListener('click', function(){ go(el.dataset.fcItem || el.dataset.fcDot); });
    });

    /* Scroll-scrub: the track above is N slides tall (100vh each). Rather
       than relying on position:sticky (which silently stops working if any
       ancestor -- e.g. Shopify's own .shopify-section wrapper -- sets
       overflow/contain/transform), the pin is managed directly here: fixed
       to the viewport while inside the track, absolute at the top/bottom
       edges before/after it. Scroll depth into the track maps to a slide. */
    var track = root.closest('.fc__track');
    var pin = track ? track.querySelector('[data-fc-pin]') : null;
    var slideCount = root.querySelectorAll('[data-fc-slide]').length;
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (track && pin && slideCount > 1 && !reduceMotion) {
      var ticking = false;
      function updateFromScroll(){
        ticking = false;
        var rect = track.getBoundingClientRect();
        var vh = window.innerHeight;

        pin.classList.remove('is-fixed', 'is-bottom');
        if (rect.top <= 0 && rect.bottom >= vh) {
          pin.classList.add('is-fixed');
          /* position:fixed's containing block is the viewport, not the
             track -- CSS alone can't know the track's real horizontal
             offset once that switch happens, so lock it here from the
             live rect or the pin drifts outside the track's actual
             left edge/width (the bug being fixed). */
          pin.style.left = rect.left + 'px';
          pin.style.width = rect.width + 'px';
        } else {
          pin.style.left = '';
          pin.style.width = '';
          if (rect.bottom < vh) pin.classList.add('is-bottom');
        }

        var scrollable = rect.height - vh;
        if (scrollable <= 0) return;
        var progress = Math.min(1, Math.max(0, -rect.top / scrollable));
        var index = Math.min(slideCount - 1, Math.floor(progress * slideCount));
        go(index);
      }
      window.addEventListener('scroll', function(){
        if (!ticking) { ticking = true; requestAnimationFrame(updateFromScroll); }
      }, { passive: true });
      window.addEventListener('resize', updateFromScroll);
      updateFromScroll();
    }

    /* Scroll-triggered entrance: fires once when ~75% of the section is
       visible, then stops observing (no repeat on scroll up). Uses
       IntersectionObserver instead of a scroll listener for performance. */
    if ('IntersectionObserver' in window) {
      var revealObserver = new IntersectionObserver(function (entries, observer) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            root.classList.add('is-revealed');
            observer.unobserve(root);
          }
        });
      }, { threshold: 0.15 });
      revealObserver.observe(root);
    } else {
      root.classList.add('is-revealed');
    }
  });
</script>

{% schema %}
{
  "name": "Featured collections",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured Collections" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Collection",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Collection" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Featured collections",
      "blocks": [
        { "type": "slide", "settings": { "title": "Bare Earth" } },
        { "type": "slide", "settings": { "title": "Plush" } },
        { "type": "slide", "settings": { "title": "Terraweave" } },
        { "type": "slide", "settings": { "title": "Soft Haven" } }
      ]
    }
  ]
}
{% endschema %}
