{%- comment -%} params: product, show_add (default true) {%- endcomment -%}
{%- assign p = product -%}
{%- assign size_value = p.metafields.custom.size -%}
{%- if size_value == blank -%}
  {%- for option in p.options_with_values -%}
    {%- if option.name == 'Size' -%}
      {%- assign size_index = option.position | minus: 1 -%}
      {%- assign size_value = p.selected_or_first_available_variant.options[size_index] -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
<div class="product-card">
  <a href="{{ p.url }}" class="product-card__media">
    {%- if p.featured_image -%}
      <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title | escape }}" width="600" height="800" loading="lazy">
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag }}
    {%- endif -%}
    <button class="product-card__wish" aria-label="Add to wishlist" type="button" data-wishlist="{{ p.id }}">{% render 'icon', icon: 'heart' %}</button>
  </a>
  <div class="product-card__body">
    <a href="{{ p.url }}">
      <h3 class="product-card__title">{{ p.title }}</h3>
    </a>
    {%- if p.metafields.custom.shade != blank -%}<p class="product-card__meta">{{ p.metafields.custom.shade }}</p>{%- endif -%}
    {%- if p.type != blank -%}<p class="product-card__meta">{{ p.type }}</p>{%- endif -%}
    {%- if size_value != blank -%}<p class="product-card__meta">{{ size_value }}</p>{%- endif -%}
    <span class="product-card__price">{{ p.price | money_without_trailing_zeros }}</span>
    {%- unless show_add == false -%}
      {%- if p.available -%}
        <product-form>
          {%- form 'product', p, class: 'product-card__form' -%}
            <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
            <button type="submit" class="product-card__add">Add to cart</button>
          {%- endform -%}
        </product-form>
      {%- else -%}
        <button class="product-card__add" disabled>Sold out</button>
      {%- endif -%}
    {%- endunless -%}
  </div>
</div>
