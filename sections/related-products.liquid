{%- comment -%} You may also like — Beds & More by Sarom {%- endcomment -%}
{%- liquid
  assign limit = section.settings.products_limit
  assign source = null
  if section.settings.collection != blank
    assign source = section.settings.collection.products
  elsif recommendations.performed and recommendations.products_count > 0
    assign source = recommendations.products
  elsif product.collections.size > 0
    assign source = product.collections.first.products
  endif
-%}

<section class="section rel" data-section-id="{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <p class="eyebrow rel__eyebrow">{{ section.settings.heading }}</p>
    {%- endif -%}

    <div class="rel__wrap">
      <button class="round-btn rel__nav rel__nav--prev" type="button" aria-label="Previous" data-rel-prev>
        {% render 'icon', icon: 'arrow-left' %}
      </button>

      <div class="rel__track" data-rel-track>
        {%- if source and source.size > 0 -%}
          {%- assign shown = 0 -%}
          {%- for item in source -%}
            {%- if item.id != product.id and shown < limit -%}
              <div class="rel__item">{% render 'product-card', product: item %}</div>
              {%- assign shown = shown | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if shown == 0 -%}
            {%- for i in (1..3) -%}
              <div class="rel__item rel__item--ph">{{ 'product-1' | placeholder_svg_tag }}</div>
            {%- endfor -%}
          {%- endif -%}
        {%- else -%}
          {%- for i in (1..3) -%}
            <div class="rel__item rel__item--ph">{{ 'product-1' | placeholder_svg_tag }}</div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <button class="round-btn rel__nav rel__nav--next" type="button" aria-label="Next" data-rel-next>
        {% render 'icon', icon: 'arrow-right' %}
      </button>
    </div>
  </div>
</section>

{%- style -%}
  .rel__eyebrow { text-align: center; letter-spacing: .28em; }
  .rel__wrap { display: flex; align-items: center; gap: 18px; margin-top: 26px; }
  .rel__nav { flex: 0 0 auto; }
  .rel__track { display: grid; grid-auto-flow: column; grid-auto-columns: calc((100% - 60px) / 3); gap: 30px; overflow-x: auto; scroll-behavior: smooth; scrollbar-width: none; flex: 1; padding: 4px; }
  .rel__track::-webkit-scrollbar { display: none; }
  .rel__item { min-width: 0; }
  .rel__item--ph { border-radius: var(--radius); overflow: hidden; background: var(--cream-2); aspect-ratio: 3/4; }
  .rel__item--ph svg { width: 100%; height: 100%; object-fit: cover; }
  @media (max-width: 990px) {
    .rel__track { grid-auto-columns: calc((100% - 30px) / 2); }
  }
  @media (max-width: 600px) {
    .rel__track { grid-auto-columns: 82%; }
    .rel__nav { display: none; }
  }
{%- endstyle -%}

<script>
(function(){
  var root = document.querySelector('#shopify-section-{{ section.id }} .rel');
  if (!root || root.dataset.relInit) return;
  root.dataset.relInit = '1';
  var track = root.querySelector('[data-rel-track]');
  function step(){ return track.clientWidth / 3 + 30; }
  root.querySelector('[data-rel-prev]').addEventListener('click', function(){ track.scrollBy({left:-step(),behavior:'smooth'}); });
  root.querySelector('[data-rel-next]').addEventListener('click', function(){ track.scrollBy({left:step(),behavior:'smooth'}); });
})();
</script>

{% schema %}
{
  "name": "Related products",
  "tag": "section",
  "class": "section-related-products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "You may also like" },
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Leave empty to use recommendations or the product's own collection." },
    { "type": "range", "id": "products_limit", "label": "Products to show", "min": 3, "max": 12, "step": 1, "default": 6 }
  ],
  "presets": [
    { "name": "Related products" }
  ]
}
{% endschema %}
