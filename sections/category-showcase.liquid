<section class="section category-showcase">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subtext != blank -%}<p class="section-sub">{{ section.settings.subtext }}</p>{%- endif -%}

    <div class="ccs-stage" data-ccs>
      {%- for block in section.blocks -%}
        <div class="ccs-card" data-ccs-card {{ block.shopify_attributes }}>
          <button class="ccs-card__hit" data-ccs-select aria-label="Show {{ block.settings.title | escape }}"></button>
          <div class="ccs-card__media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.title | escape }}" width="1200" height="900" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <span class="ccs-card__num">/{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <div class="ccs-card__content">
            <a href="{{ block.settings.link }}" class="ccs-card__title" data-ccs-stop>{{ block.settings.title }}</a>
            <a class="btn ccs-card__view" href="{{ section.settings.button_link }}" data-ccs-stop>{{ section.settings.button_label }}</a>
            <button class="round-btn ccs-card__next" data-ccs-next data-ccs-stop aria-label="Next category">{% render 'icon', icon: 'arrow-right' %}</button>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .ccs-stage { position: relative; height: 460px; width: 100%; margin: 40px 0; overflow: hidden; border-radius: var(--radius); }
  .ccs-card {
    position: absolute; left: 0; top: 0;
    width: 78%; height: 100%;
    border-radius: var(--radius); overflow: hidden;
    background: var(--cream-2);
    transform-origin: left center;
    transition: transform 1050ms cubic-bezier(.22,1,.36,1),
                opacity 1050ms cubic-bezier(.22,1,.36,1),
                filter 1050ms cubic-bezier(.22,1,.36,1);
    will-change: transform, opacity, filter;
  }
  .ccs-card::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(20,16,12,0) 45%, rgba(20,16,12,.4) 100%); pointer-events: none; }
  .ccs-card__hit { position: absolute; inset: 0; z-index: 1; background: none; border: none; padding: 0; cursor: pointer; }
  .ccs-card[data-active="true"] .ccs-card__hit { cursor: default; }
  .ccs-card__media { position: absolute; inset: 0; }
  .ccs-card__media img, .ccs-card__media svg { width: 100%; height: 100%; object-fit: cover; }
  .ccs-card__num { position: absolute; top: 26px; left: 30px; color: var(--brown-2); font-size: 13px; letter-spacing: .08em; z-index: 2; }
  .ccs-card__content { position: absolute; inset: 0; z-index: 2; pointer-events: none; opacity: 0; transition: opacity .4s ease; }
  .ccs-card[data-active="true"] .ccs-card__content { opacity: 1; pointer-events: auto; }
  .ccs-card[data-active="true"] .ccs-card__content a,
  .ccs-card[data-active="true"] .ccs-card__content button { pointer-events: auto; }
  .ccs-card__title { position: absolute; top: 44px; left: 30px; color: var(--brown); font-family: var(--font-serif); font-size: 34px; }
  .ccs-card__view { position: absolute; left: 30px; bottom: 30px; }
  .ccs-card__next { position: absolute; right: 30px; bottom: 30px; background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.6); color: #fff; }
  .ccs-card__next:hover { background: #fff; color: var(--brown); }

  @media (max-width: 860px) {
    .ccs-stage { height: 340px; }
    .ccs-card__title { font-size: 24px; }
  }
</style>

<script>
  document.querySelectorAll('[data-ccs]').forEach(function (stage) {
    if (stage.dataset.ccsInit) return;
    stage.dataset.ccsInit = '1';

    var cards = Array.prototype.slice.call(stage.querySelectorAll('[data-ccs-card]'));
    if (!cards.length) return;

    var order = cards.map(function (_, i) { return i; });
    var timer = null;

    /* xFrac/yFrac are fractions of the stage's own rendered width, so the
       stack always fills the stage edge-to-edge and stays centered at any
       screen size or stage width. */
    var POS = [
      { x: 0,     y: 0,     s: 1,   o: 1,    z: 5, r: 0,    blur: 0 },
      { x: .052,  y: .020,  s: .95, o: 1,    z: 4, r: -1.2,  blur: 0 },
      { x: .098,  y: .038,  s: .90, o: .97,  z: 3, r: -2.1,  blur: 0 },
      { x: .132,  y: .054,  s: .85, o: .93,  z: 2, r: -2.8,  blur: 0 },
      { x: .160,  y: .066,  s: .80, o: .88,  z: 1, r: -3.4,  blur: .5 }
    ];
    var HIDDEN = { x: .19, y: .08, s: .75, o: 0, z: 0, r: -4, blur: 4 };

    function apply() {
      var stageWidth = stage.clientWidth;
      order.forEach(function (cardIndex, pos) {
        var card = cards[cardIndex];
        var p = POS[pos] || HIDDEN;
        var x = p.x * stageWidth;
        var y = p.y * stageWidth;
        card.style.transform = 'translate(' + x + 'px,' + y + 'px) scale(' + p.s + ') rotate(' + p.r + 'deg)';
        card.style.opacity = p.o;
        card.style.zIndex = p.z;
        card.style.filter = p.blur ? 'blur(' + p.blur + 'px)' : 'none';
        card.style.pointerEvents = p.o === 0 ? 'none' : 'auto';
        card.dataset.active = pos === 0 ? 'true' : 'false';
      });
    }

    function rotate(steps) {
      steps = ((steps % order.length) + order.length) % order.length;
      for (var i = 0; i < steps; i++) order.push(order.shift());
      apply();
      restartAutoplay();
    }

    function restartAutoplay() {
      if (timer) clearInterval(timer);
      timer = setInterval(function () { rotate(1); }, 10000);
    }

    cards.forEach(function (card) {
      card.querySelectorAll('[data-ccs-stop]').forEach(function (el) {
        el.addEventListener('click', function (e) { e.stopPropagation(); });
      });
      var hit = card.querySelector('[data-ccs-select]');
      hit.addEventListener('click', function () {
        var pos = order.indexOf(cards.indexOf(card));
        if (pos > 0) rotate(pos);
      });
      var next = card.querySelector('[data-ccs-next]');
      if (next) next.addEventListener('click', function (e) { e.stopPropagation(); rotate(1); });
    });

    stage.addEventListener('mouseenter', function () { if (timer) clearInterval(timer); });
    stage.addEventListener('mouseleave', restartAutoplay);

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(apply, 100);
    });

    /* Mobile swipe: swipe left = next, swipe right = previous. */
    var touchStartX = 0;
    stage.addEventListener('touchstart', function (e) {
      touchStartX = e.touches[0].clientX;
      if (timer) clearInterval(timer);
    }, { passive: true });
    stage.addEventListener('touchend', function (e) {
      var dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) rotate(dx < 0 ? 1 : -1);
      else restartAutoplay();
    }, { passive: true });

    apply();
    restartAutoplay();
  });
</script>

{% schema %}
{
  "name": "Category showcase",
  "settings": [
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Shop by <em>category</em>" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "One knitted-cotton family, three ways to layer your bed — across nine shades drawn from the earth." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "View all" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category showcase",
      "blocks": [
        { "type": "category", "settings": { "title": "Bed covers" } },
        { "type": "category", "settings": { "title": "Comforters" } },
        { "type": "category", "settings": { "title": "Throws" } },
        { "type": "category", "settings": { "title": "Pillow covers" } },
        { "type": "category", "settings": { "title": "Cushions" } }
      ]
    }
  ]
}
{% endschema %}
