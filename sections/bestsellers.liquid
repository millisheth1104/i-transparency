<section class="section bestsellers">
  <div class="container">
    <p class="eyebrow text-center">{{ section.settings.eyebrow }}</p>
    {%- if section.settings.subheading != blank -%}<p class="section-sub" style="margin-top:0">{{ section.settings.subheading }}</p>{%- endif -%}

    <div class="bs-wrap">
      <button class="round-btn bs-arrow bs-arrow--prev" data-scroll-prev aria-label="Previous">{% render 'icon', icon: 'arrow-left' %}</button>

      <div class="bs-row" data-scroll>
        {%- assign coll = collections[section.settings.collection] -%}
        {%- if coll != empty and coll.products.size > 0 -%}
          {%- for product in coll.products limit: section.settings.limit -%}
            <div class="bs-item">{% render 'product-card', product: product %}</div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..3) -%}
            <div class="bs-item">
              <div class="product-card">
                <div class="product-card__media">{{ 'product-1' | placeholder_svg_tag }}</div>
                <div class="product-card__body">
                  <h3 class="product-card__title">Product title</h3>
                  <p class="product-card__meta">Variant · Size</p>
                  <span class="product-card__price">₹0</span>
                  <button class="product-card__add">Add to cart</button>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <button class="round-btn bs-arrow bs-arrow--next" data-scroll-next aria-label="Next">{% render 'icon', icon: 'arrow-right' %}</button>
    </div>
  </div>
</section>

<style>
  .bestsellers .eyebrow { margin-bottom: 6px; }
  .bs-wrap { position: relative; margin-top: 34px; }
  .bs-row { display: grid; grid-auto-flow: column; grid-auto-columns: calc((100% - 60px) / 3); gap: 30px; overflow-x: auto; scroll-behavior: smooth; scrollbar-width: none; padding-bottom: 6px; }
  .bs-row::-webkit-scrollbar { display: none; }
  .bs-arrow { position: absolute; top: 34%; z-index: 2; background: var(--cream); }
  .bs-arrow--prev { left: -26px; }
  .bs-arrow--next { right: -26px; }
  @media (max-width: 990px){ .bs-row { grid-auto-columns: 70%; } .bs-arrow { display: none; } }
</style>

<script>
  document.querySelectorAll('.bestsellers').forEach(function(sec){
    var row = sec.querySelector('[data-scroll]');
    sec.querySelector('[data-scroll-next]')?.addEventListener('click', function(){ row.scrollBy({left: row.clientWidth/3 + 30, behavior:'smooth'}); });
    sec.querySelector('[data-scroll-prev]')?.addEventListener('click', function(){ row.scrollBy({left: -(row.clientWidth/3 + 30), behavior:'smooth'}); });
  });
</script>

{% schema %}
{
  "name": "Bestsellers",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bestsellers" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Loved by 1,200+ homes" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products", "min": 3, "max": 12, "step": 1, "default": 8 }
  ],
  "presets": [{ "name": "Bestsellers" }]
}
{% endschema %}
